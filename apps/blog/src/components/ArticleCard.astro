---
import { getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { PRIMARY_CTA, SECONDARY_CTA, SHELL_COPY, articlePath } from '../consts';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, excerpt, pubDate, featuredImage, category } = post.data;
const categoryId = typeof category === 'string' ? category : ('id' in category ? category.id : category.slug);
const categoryEntry = categoryId ? await getEntry('categories', categoryId) : undefined;
const categoryName = categoryEntry?.data.name ?? categoryId ?? 'Article';
---

<article class="shell-card group overflow-hidden p-5 md:p-6">
  <a href={articlePath(post.slug)} class="block">
    {featuredImage ? (
      <div class="mb-5 aspect-[1.4] overflow-hidden rounded-xl bg-[var(--surface-tertiary)]">
        <img
          src={featuredImage.src}
          alt={featuredImage.alt}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="mb-5 rounded-xl bg-[var(--accent-light)] p-6">
        <span class="eyebrow">{SHELL_COPY.articleContextLabel}</span>
        <div class="mt-4">
          <p class="text-xl font-semibold">{categoryName}</p>
          <p class="mt-2 max-w-xs text-sm leading-relaxed text-[var(--ink-secondary)]">{excerpt}</p>
        </div>
      </div>
    )}

    <span class="eyebrow">{categoryName}</span>
    <h3 class="mt-2 text-xl font-semibold tracking-tight transition-colors group-hover:text-[var(--accent-hover)]">
      {title}
    </h3>
    <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-[var(--ink-secondary)]">{excerpt}</p>

    <div class="mt-4 flex items-center justify-between gap-4 text-sm">
      <time class="text-[var(--ink-muted)]" datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
      </time>
      <span class="font-medium text-[var(--accent)]">{SHELL_COPY.articlePrimaryActionText}</span>
    </div>
  </a>
</article>