---
import { getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { PRIMARY_CTA, SECONDARY_CTA, SHELL_COPY, articlePath } from '../consts';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, excerpt, pubDate, featuredImage, category } = post.data;
const categoryId = typeof category === 'string' ? category : ('id' in category ? category.id : category.slug);
const categoryEntry = categoryId ? await getEntry('categories', categoryId) : undefined;
const categoryName = categoryEntry?.data.name ?? categoryId ?? 'Artikkel';
---

<article class="shell-card group overflow-hidden p-5 md:p-6">
  <a href={articlePath(post.slug)} class="block">
    {featuredImage ? (
      <div class="mb-5 aspect-[1.4] overflow-hidden rounded-[1.35rem] bg-slate-100">
        <img
          src={featuredImage.src}
          alt={featuredImage.alt}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="mb-5 rounded-[1.35rem] bg-gradient-to-br from-teal-50 via-white to-slate-100 p-6">
        <span class="eyebrow">{SHELL_COPY.articleContextLabel}</span>
        <div class="mt-5 flex items-end justify-between gap-4">
          <div>
            <p class="display-title text-2xl font-bold text-slate-900">{categoryName}</p>
            <p class="mt-2 max-w-xs text-sm leading-6 text-slate-600">{excerpt}</p>
          </div>
          <span class="rounded-full border border-teal-200 bg-white px-3 py-1 text-xs font-bold uppercase tracking-[0.16em] text-teal-700">
            {SHELL_COPY.articleLanguageBadge}
          </span>
        </div>
      </div>
    )}

    <span class="eyebrow">{categoryName}</span>
    <h3 class="mt-2 text-2xl font-extrabold tracking-tight text-slate-900 transition-colors group-hover:text-teal-800">
      {title}
    </h3>
    <p class="mt-3 line-clamp-3 text-sm leading-7 text-slate-600">{excerpt}</p>

    <div class="mt-5 flex items-center justify-between gap-4 text-sm">
      <time class="font-semibold text-slate-500" datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString('nb-NO', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <span class="font-bold text-teal-700">{SHELL_COPY.articlePrimaryActionText}</span>
    </div>
  </a>

  <div class="mt-5 border-t border-slate-200/80 pt-4 text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">
    <a href={SECONDARY_CTA.href} class="transition-colors hover:text-slate-900">{SECONDARY_CTA.label}</a>
    <span class="mx-2">/</span>
    <a href={PRIMARY_CTA.href} class="transition-colors hover:text-slate-900">{PRIMARY_CTA.label}</a>
  </div>
</article>
