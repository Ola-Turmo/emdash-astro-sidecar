---
/**
 * BlogFooter.astro
 * 
 * Blog footer component with:
 * - About/description text
 * - Quick links
 * - Categories list
 * - RSS feed link
 * - Copyright
 */

interface Props {
  currentYear?: number;
}

const { currentYear = new Date().getFullYear() } = Astro.props;

// Categories for the footer
const categories = [
  { name: 'Technology', href: '/category/technology' },
  { name: 'Development', href: '/category/development' },
  { name: 'Design', href: '/category/design' },
  { name: 'Tutorial', href: '/category/tutorial' },
];

// Quick links
const quickLinks = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Contact', href: '/contact' },
  { name: 'Privacy Policy', href: '/privacy' },
  { name: 'Terms of Service', href: '/terms' },
];
---

<footer class="footer-component py-12 border-t border-border">
  <div class="container mx-auto max-w-4xl px-4">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- About Column -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20" />
          </svg>
          <span class="font-bold text-lg">EmDash Blog</span>
        </div>
        <p class="text-sm text-muted-foreground mb-4 max-w-md">
          A modern blog built with Astro, featuring cutting-edge web technologies 
          and best practices. We share insights on development, design, and technology.
        </p>
        
        <!-- Social Links -->
        <div class="flex items-center gap-3">
          <a
            href="https://twitter.com/emdash"
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 rounded-lg hover:bg-accent transition-colors text-muted-foreground hover:text-foreground"
            aria-label="Follow us on Twitter"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z" />
            </svg>
          </a>
          <a
            href="https://github.com/emdash"
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 rounded-lg hover:bg-accent transition-colors text-muted-foreground hover:text-foreground"
            aria-label="View our GitHub"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
              <path d="M9 18c-4.51 2-5-2-7-2" />
            </svg>
          </a>
          <a
            href="/rss.xml"
            class="p-2 rounded-lg hover:bg-accent transition-colors text-muted-foreground hover:text-foreground"
            aria-label="RSS Feed"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 11a9 9 0 0 1 9 9" />
              <path d="M4 4a16 16 0 0 1 16 16" />
              <circle cx="5" cy="19" r="1" />
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Quick Links Column -->
      <div>
        <h3 class="font-semibold mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {quickLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm text-muted-foreground hover:text-foreground transition-colors"
              >
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Categories Column -->
      <div>
        <h3 class="font-semibold mb-4">Categories</h3>
        <ul class="space-y-2">
          {categories.map(cat => (
            <li>
              <a
                href={cat.href}
                class="text-sm text-muted-foreground hover:text-foreground transition-colors"
              >
                {cat.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    
    <!-- Copyright Bar -->
    <div class="mt-12 pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-muted-foreground">
        © {currentYear} EmDash Blog. All rights reserved.
      </p>
      <p class="text-sm text-muted-foreground">
        Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Astro</a>
      </p>
    </div>
  </div>
</footer>
