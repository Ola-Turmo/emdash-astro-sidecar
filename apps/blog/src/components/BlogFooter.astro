---
import { COURSE_LINKS, MAIN_SITE_URL, SITE_NAME, blogPath } from '../consts';

interface Props {
  currentYear?: number;
}

const { currentYear = new Date().getFullYear() } = Astro.props;
---

<footer class="footer-component border-t border-border py-12">
  <div class="container mx-auto max-w-4xl px-4">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <div>
        <span class="font-bold text-lg">{SITE_NAME}</span>
        <p class="mt-3 max-w-md text-sm text-muted-foreground">
          Forklarende artikler som hjelper leseren å forstå krav, ansvar og veien videre til riktig kurs.
        </p>
      </div>

      <div>
        <h3 class="mb-4 font-semibold">Kurs</h3>
        <ul class="space-y-2">
          {COURSE_LINKS.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 font-semibold">Teknisk</h3>
        <ul class="space-y-2">
          <li><a href={blogPath('/rss.xml')} class="text-sm text-muted-foreground transition-colors hover:text-foreground">RSS</a></li>
          <li><a href={blogPath('/sitemap.xml')} class="text-sm text-muted-foreground transition-colors hover:text-foreground">Sitemap</a></li>
          <li><a href={MAIN_SITE_URL} class="text-sm text-muted-foreground transition-colors hover:text-foreground">Hovedside</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-border pt-8">
      <p class="text-sm text-muted-foreground">© {currentYear} {SITE_NAME}.</p>
    </div>
  </div>
</footer>
