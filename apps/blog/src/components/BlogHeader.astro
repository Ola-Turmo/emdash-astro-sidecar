---
import { MAIN_NAV, SITE_NAME, blogPath } from '../consts';

interface Props {
  currentPath?: string;
}

const { currentPath = blogPath('/') } = Astro.props;

const navItems = MAIN_NAV;

const isActive = (href: string) => {
  if (href === blogPath('/')) return currentPath === href;
  return currentPath.startsWith(href);
};
---

<header class="fixed top-6 left-1/2 -translate-x-1/2 z-50 w-[calc(100%-2rem)] max-w-[52rem]">
  <nav class="mx-auto flex items-center justify-between gap-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]/90 px-5 py-3 backdrop-blur-xl shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
    <a href={blogPath('/')} class="text-base font-semibold tracking-tight text-[var(--color-ink)] transition-opacity hover:opacity-70">
      {SITE_NAME}
    </a>

    <div class="hidden items-center gap-7 md:flex">
      {navItems.map((item: (typeof navItems)[number]) => (
        <a
          href={item.href}
          class:list={[
            'text-[0.8125rem] font-medium transition-colors',
            isActive(item.href) ? 'text-[var(--color-ink)]' : 'text-[var(--color-muted)] hover:text-[var(--color-ink)]',
          ]}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </div>

    <a href={blogPath('/rss.xml')} class="text-xs font-medium text-[var(--color-muted)] transition-colors hover:text-[var(--color-ink)]">
      RSS
    </a>
  </nav>
</header>