---
import { MAIN_NAV, SITE_NAME, blogPath } from '../consts';

interface Props {
  currentPath?: string;
}

const { currentPath = blogPath('/') } = Astro.props;

const navItems = MAIN_NAV;

const isActive = (href: string) => {
  if (href === blogPath('/')) return currentPath === href;
  return currentPath.startsWith(href);
};
---

<header class="header-component">
  <nav class="container mx-auto max-w-4xl px-4">
    <div class="flex h-16 items-center justify-between">
      <a href={blogPath('/')} class="flex items-center gap-2 text-xl font-bold transition-colors hover:text-primary">
        <span>{SITE_NAME}</span>
      </a>

      <div class="hidden items-center gap-6 md:flex">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-primary',
              isActive(item.href) ? 'text-primary' : 'text-muted-foreground',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </div>

      <a href={blogPath('/rss.xml')} class="text-sm text-muted-foreground transition-colors hover:text-foreground">
        RSS
      </a>
    </div>
  </nav>
</header>
