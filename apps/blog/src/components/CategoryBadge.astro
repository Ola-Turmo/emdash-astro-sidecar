---
/**
 * CategoryBadge.astro
 * 
 * A colored pill/badge component that displays a category name and links to its page.
 */

interface Props {
  name: string;
  slug: string;
  color: string;
  size?: 'sm' | 'md';
}

const { name, slug, color, size = 'md' } = Astro.props;

// Generate a lighter background color from the hex color
function hexToRgba(hex: string, alpha: number): string {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `rgba(${r}, ${g}, ${b}, ${alpha})`;
}

const bgColor = hexToRgba(color, 0.15);
const textColor = color;

const sizeClasses = size === 'sm' 
  ? 'px-2 py-0.5 text-xs' 
  : 'px-3 py-1 text-sm';
---

<a 
  href={`/category/${slug}`}
  class={`inline-flex items-center rounded-full font-medium transition-colors hover:opacity-80 ${sizeClasses}`}
  style={`background-color: ${bgColor}; color: ${textColor};`}
>
  {name}
</a>