---
import {
  COURSE_LINKS,
  MAIN_SITE_URL,
  PRIMARY_CTA,
  SHELL_COPY,
  SITE_WORDMARK,
  SUPPORT_EMAIL,
  blogPath,
} from '../consts';

const currentYear = new Date().getFullYear();
const footerNav = [
  { href: blogPath('/rss.xml'), label: 'RSS' },
  { href: blogPath('/sitemap.xml'), label: 'Sitemap' },
  { href: MAIN_SITE_URL, label: SITE_WORDMARK },
  { href: `mailto:${SUPPORT_EMAIL}`, label: 'Email' },
];
---

<footer class="mt-24 border-t border-[var(--color-border)]">
  <div class="mx-auto max-w-6xl px-4 pt-16 pb-12 md:pt-24 md:pb-16">
    <div class="grid gap-12 md:grid-cols-[1.2fr,0.8fr]">
      <div class="space-y-5">
        <p class="eyebrow">{SHELL_COPY.footerEyebrow}</p>
        <h2 class="display-title text-2xl font-semibold text-[var(--color-ink)] md:text-3xl">
          {SHELL_COPY.footerTitle}
        </h2>
        <p class="max-w-xl text-[0.9375rem] leading-7 text-[var(--color-muted)]">
          {SHELL_COPY.footerDescription}
        </p>
        <div class="flex flex-wrap gap-3 pt-1">
          <a href={PRIMARY_CTA.href} class="cta-primary">{PRIMARY_CTA.label}</a>
          <a href={`mailto:${SUPPORT_EMAIL}`} class="cta-secondary">{SHELL_COPY.footerContactLabel}</a>
        </div>
      </div>

      <div class="grid gap-10 sm:grid-cols-2 md:gap-8">
        {COURSE_LINKS.length > 0 && (
          <div>
            <p class="mb-4 text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-[var(--color-ink)]">{SHELL_COPY.footerOffersLabel}</p>
            <div class="space-y-3">
              {COURSE_LINKS.map((link: (typeof COURSE_LINKS)[number]) => (
                <a href={link.href} class="block transition-colors hover:text-[var(--color-accent)]">
                  <span class="block text-sm font-medium text-[var(--color-ink)]">{link.label}</span>
                  <span class="block text-sm text-[var(--color-muted)]">{link.description}</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <div>
          <p class="mb-4 text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-[var(--color-ink)]">{SHELL_COPY.footerTechnicalLabel}</p>
          <div class="space-y-2.5 text-sm">
            {footerNav.map((link) => (
              <a href={link.href} class="block text-[var(--color-muted)] transition-colors hover:text-[var(--color-ink)]">{link.label}</a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-[var(--color-border)]">
    <div class="mx-auto flex max-w-6xl flex-col gap-2 px-4 py-5 text-sm text-[var(--color-muted)] md:flex-row md:items-center md:justify-between">
      <p>&copy; {currentYear} {SITE_WORDMARK}. {SHELL_COPY.footerCopyright}</p>
      <p>{SHELL_COPY.footerNote}</p>
    </div>
  </div>
</footer>