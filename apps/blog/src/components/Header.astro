---
import {
  ACTIVE_CONCEPT_KEY,
  CONCEPT_PAGE_STRUCTURE,
  MAIN_NAV,
  PRIMARY_CTA,
  SECONDARY_CTA,
  SITE_LOGO_MARK,
  SITE_WORDMARK,
  SHELL_COPY,
  conceptPath,
  articlePath,
} from '../consts';
import { getPublishedMunicipalPages } from '../lib/published-content';

const isMunicipalityConcept = ACTIVE_CONCEPT_KEY === 'kommune' && CONCEPT_PAGE_STRUCTURE === 'directory';
const municipalityNav = isMunicipalityConcept
  ? (await getPublishedMunicipalPages())
      .sort((a, b) => a.data.municipality.localeCompare(b.data.municipality, 'nb'))
      .slice(0, 4)
      .map((page) => ({
        href: articlePath(page.slug),
        label: page.data.municipality,
      }))
  : [];
const resolvedNav: Array<{ href: string; label: string }> = isMunicipalityConcept
  ? [{ href: conceptPath('/'), label: MAIN_NAV[0]?.label ?? 'Kommuner' }, ...municipalityNav]
  : MAIN_NAV;
---

<header class="fixed top-6 left-1/2 -translate-x-1/2 z-50 w-[calc(100%-2rem)] max-w-[52rem]">
  <nav class="mx-auto flex items-center justify-between gap-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]/90 px-5 py-3 backdrop-blur-xl shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
    <a href={conceptPath('/')} class="flex items-center gap-2.5 transition-opacity hover:opacity-70">
      <span class="flex h-8 w-8 items-center justify-center rounded-md bg-[var(--color-ink)] text-sm font-bold text-white">
        {SITE_LOGO_MARK}
      </span>
      <span class="text-base font-semibold tracking-tight text-[var(--color-ink)]">{SITE_WORDMARK}</span>
    </a>

    <div class="hidden items-center gap-7 lg:flex">
      {resolvedNav.map((link: (typeof resolvedNav)[number]) => (
        <a
          href={link.href}
          class="text-[0.8125rem] font-medium text-[var(--color-muted)] transition-colors hover:text-[var(--color-ink)]"
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a href={SECONDARY_CTA.href} class="hidden text-[0.8125rem] font-medium text-[var(--color-muted)] transition-colors hover:text-[var(--color-ink)] sm:inline">
        {SECONDARY_CTA.label}
      </a>
      <a href={PRIMARY_CTA.href} class="cta-primary !py-2.5 !px-4 !text-[0.8125rem]">
        {PRIMARY_CTA.label}
      </a>
    </div>
  </nav>
</header>

<div class="lg:hidden border-b border-[var(--color-border)] bg-[var(--color-surface)]/80 backdrop-blur-xl mt-[4.5rem]">
  <div data-mobile-scroll class="mx-auto flex max-w-6xl gap-4 overflow-x-auto px-4 py-3 text-[0.8125rem] font-medium text-[var(--color-muted)]">
    {resolvedNav.map((link: (typeof resolvedNav)[number]) => (
      <a href={link.href} class="whitespace-nowrap transition-colors hover:text-[var(--color-ink)]">
        {link.label}
      </a>
    ))}
  </div>
</div>