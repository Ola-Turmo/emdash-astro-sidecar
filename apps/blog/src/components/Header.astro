---
import {
  ACTIVE_CONCEPT_KEY,
  CONCEPT_PAGE_STRUCTURE,
  MAIN_NAV,
  PRIMARY_CTA,
  SECONDARY_CTA,
  SITE_LOGO_MARK,
  SITE_WORDMARK,
  SHELL_COPY,
  conceptPath,
  articlePath,
} from '../consts';
import { getPublishedMunicipalPages } from '../lib/published-content';

const isMunicipalityConcept = ACTIVE_CONCEPT_KEY === 'kommune' && CONCEPT_PAGE_STRUCTURE === 'directory';
const municipalityNav = isMunicipalityConcept
  ? (await getPublishedMunicipalPages())
      .sort((a, b) => a.data.municipality.localeCompare(b.data.municipality, 'nb'))
      .slice(0, 4)
      .map((page) => ({
        href: articlePath(page.slug),
        label: page.data.municipality,
      }))
  : [];
const resolvedNav: Array<{ href: string; label: string }> = isMunicipalityConcept
  ? [{ href: conceptPath('/'), label: MAIN_NAV[0]?.label ?? 'Kommuner' }, ...municipalityNav]
  : MAIN_NAV;
---

<header class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/80 backdrop-blur-xl">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-3 py-3 sm:gap-4 sm:px-4 sm:py-4">
    <a href={conceptPath('/')} class="inline-flex items-center gap-3">
      <span class="flex h-9 w-9 items-center justify-center rounded-2xl bg-[#115E59] text-base font-black text-white shadow-lg shadow-teal-900/20 sm:h-11 sm:w-11 sm:text-xl">
        {SITE_LOGO_MARK}
      </span>
      <span class="min-w-0">
        <span class="block text-sm font-extrabold tracking-tight text-slate-900 sm:text-lg">{SITE_WORDMARK}</span>
        <span class="block text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500 sm:text-xs">{SHELL_COPY.subLabel}</span>
      </span>
    </a>

    <nav class="hidden items-center gap-6 lg:flex">
      {resolvedNav.map((link: (typeof resolvedNav)[number]) => (
        <a
          href={link.href}
          class="text-sm font-semibold text-slate-600 transition-colors hover:text-slate-900"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <a href={SECONDARY_CTA.href} class="hidden text-sm font-semibold text-slate-600 transition-colors hover:text-slate-900 sm:inline">
        {SECONDARY_CTA.label}
      </a>
      <a href={PRIMARY_CTA.href} class="cta-primary px-4 py-2.5 text-xs sm:text-sm">
        {PRIMARY_CTA.label}
      </a>
    </div>
  </div>
</header>

<div class="border-b border-slate-200/70 bg-white/50 lg:hidden">
  <div data-mobile-scroll class="mx-auto flex max-w-6xl gap-3 overflow-x-auto px-3 py-2 text-xs font-semibold text-slate-600 sm:px-4 sm:text-sm">
    {resolvedNav.map((link: (typeof resolvedNav)[number]) => (
      <a href={link.href} class="whitespace-nowrap transition-colors hover:text-slate-900">
        {link.label}
      </a>
    ))}
  </div>
</div>
