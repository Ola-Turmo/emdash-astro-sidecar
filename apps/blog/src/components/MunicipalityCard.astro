---
import type { CollectionEntry } from 'astro:content';
import { PRIMARY_CTA, SHELL_COPY, articlePath, blogPath } from '../consts';
import { deriveMunicipalityView } from '../lib/municipality-view';

interface Props {
  page: CollectionEntry<'municipalPages'>;
}

const { page } = Astro.props;
const {
  municipality,
  county,
  municipalityNumber,
  publicRecordsPlatform,
  municipalitySitePlatform,
  heroImage,
} = page.data;
const municipalityView = deriveMunicipalityView(page.data);
const summaryRows = municipalityView.summaryRows.slice(0, 2);
const heroImageSrc = heroImage?.src
  ? blogPath(heroImage.src.replace(/-hero\.png$/i, '-hero-thumb.webp').replace(/\.png$/i, '.webp'))
  : null;
---

<article class="shell-card group overflow-hidden reveal">
  <a href={articlePath(page.slug)} class="block p-5 md:p-6">
    {heroImage && (
      <div class="-mx-5 -mt-5 mb-5 overflow-hidden rounded-t-[11px] md:-mx-6 md:-mt-6">
        <img
          src={heroImageSrc}
          alt={heroImage.alt}
          class="h-44 w-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.03]"
          loading="lazy"
        />
      </div>
    )}

    <span class="eyebrow">{county || SHELL_COPY.directoryCard?.metaFallback || SHELL_COPY.directorySearchMetaFallback}</span>
    <h3 class="mt-2 text-xl font-semibold tracking-tight text-[var(--color-ink)] transition-colors group-hover:text-[var(--color-accent)]">
      {municipality}
    </h3>
    <p class="mt-2 text-sm leading-7 text-[var(--color-muted)]">
      {municipalityView.cardSummary}
    </p>

    <dl class="mt-4 grid gap-2.5 text-sm text-[var(--color-muted)]">
      {municipalityNumber && (
        <div>
          <dt class="font-medium text-[var(--color-ink)]">{SHELL_COPY.directoryCard?.municipalityNumberLabel}</dt>
          <dd>{municipalityNumber}</dd>
        </div>
      )}
      {publicRecordsPlatform && (
        <div>
          <dt class="font-medium text-[var(--color-ink)]">{SHELL_COPY.directoryCard?.publicRecordsLabel}</dt>
          <dd>{publicRecordsPlatform}</dd>
        </div>
      )}
      {municipalitySitePlatform && (
        <div>
          <dt class="font-medium text-[var(--color-ink)]">{SHELL_COPY.directoryCard?.websiteLabel}</dt>
          <dd>{municipalitySitePlatform}</dd>
        </div>
      )}
      {summaryRows.map((row) => (
        <div>
          <dt class="font-medium text-[var(--color-ink)]">{row.label}</dt>
          <dd>{row.value}</dd>
        </div>
      ))}
    </dl>

    <div class="mt-4 flex items-center justify-between gap-4 text-sm">
      <span class="text-[var(--color-muted)]">{county || 'Norge'}</span>
      <span class="font-medium text-[var(--color-accent)]">{SHELL_COPY.articlePrimaryActionText}</span>
    </div>
  </a>

  <div class="border-t border-[var(--color-border)] px-5 py-3 md:px-6">
    <a href={PRIMARY_CTA.href} class="text-xs font-medium text-[var(--color-muted)] transition-colors hover:text-[var(--color-ink)]">{PRIMARY_CTA.label}</a>
  </div>
</article>