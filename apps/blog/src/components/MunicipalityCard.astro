---
import type { CollectionEntry } from 'astro:content';
import { PRIMARY_CTA, articlePath, blogPath } from '../consts';
import { deriveMunicipalityView } from '../lib/municipality-view';

interface Props {
  page: CollectionEntry<'municipalPages'>;
}

const { page } = Astro.props;
const {
  municipality,
  county,
  municipalityNumber,
  publicRecordsPlatform,
  municipalitySitePlatform,
  heroImage,
} = page.data;
const municipalityView = deriveMunicipalityView(page.data);
const summaryRows = municipalityView.summaryRows.slice(0, 2);
const heroImageSrc = heroImage?.src
  ? blogPath(heroImage.src.replace(/-hero\.png$/i, '-hero-thumb.webp').replace(/\.png$/i, '.webp'))
  : null;
---

<article class="shell-card group overflow-hidden p-5 md:p-6">
  <a href={articlePath(page.slug)} class="block">
    {heroImage && (
      <div class="-mx-5 -mt-5 mb-5 overflow-hidden md:-mx-6 md:-mt-6">
        <img
          src={heroImageSrc}
          alt={heroImage.alt}
          class="h-44 w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
          loading="lazy"
        />
      </div>
    )}

    <span class="eyebrow">{county || 'Kommune'}</span>
    <h3 class="mt-2 text-2xl font-extrabold tracking-tight text-slate-900 transition-colors group-hover:text-teal-800">
      {municipality}
    </h3>
    <p class="mt-3 text-sm leading-7 text-slate-600">
      {municipalityView.cardSummary}
    </p>

    <dl class="mt-5 grid gap-3 text-sm text-slate-600">
      {municipalityNumber && (
        <div>
          <dt class="font-bold text-slate-900">Kommunenummer</dt>
          <dd>{municipalityNumber}</dd>
        </div>
      )}
      {publicRecordsPlatform && (
        <div>
          <dt class="font-bold text-slate-900">Innsyn</dt>
          <dd>{publicRecordsPlatform}</dd>
        </div>
      )}
      {municipalitySitePlatform && (
        <div>
          <dt class="font-bold text-slate-900">Nettside</dt>
          <dd>{municipalitySitePlatform}</dd>
        </div>
      )}
      {summaryRows.map((row) => (
        <div>
          <dt class="font-bold text-slate-900">{row.label}</dt>
          <dd>{row.value}</dd>
        </div>
      ))}
    </dl>

    <div class="mt-5 flex items-center justify-between gap-4 text-sm">
      <span class="font-semibold text-slate-500">{county || 'Norge'}</span>
      <span class="font-bold text-teal-700">Les kommunesiden</span>
    </div>
  </a>

  <div class="mt-5 border-t border-slate-200/80 pt-4 text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">
    <a href={PRIMARY_CTA.href} class="transition-colors hover:text-slate-900">{PRIMARY_CTA.label}</a>
  </div>
</article>
