---
/**
 * Pagination.astro
 * 
 * A reusable pagination component with Previous/Next buttons and page numbers.
 * Handles edge cases: first page (no prev), last page (no next), ellipsis for many pages.
 */

interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

// Ensure we have valid pagination
const safeCurrentPage = Math.max(1, Math.min(currentPage, totalPages));

// Build URL helper
function getPageUrl(page: number): string {
  if (page === 1) return baseUrl;
  return `${baseUrl}${baseUrl.endsWith('/') ? '' : '/'}page/${page}`;
}

// Generate page numbers with ellipsis
function getPageNumbers(current: number, total: number): (number | '...')[] {
  if (total <= 7) {
    return Array.from({ length: total }, (_, i) => i + 1);
  }
  
  const pages: (number | '...')[] = [];
  
  if (current <= 3) {
    pages.push(1, 2, 3, 4, '...', total);
  } else if (current >= total - 2) {
    pages.push(1, '...', total - 3, total - 2, total - 1, total);
  } else {
    pages.push(1, '...', current - 1, current, current + 1, '...', total);
  }
  
  return pages;
}

const pageNumbers = getPageNumbers(safeCurrentPage, totalPages);
const hasPrev = safeCurrentPage > 1;
const hasNext = safeCurrentPage < totalPages;
---

{totalPages > 1 && (
  <nav class="flex items-center justify-center gap-2" aria-label="Pagination">
    {/* Previous Button */}
    {hasPrev ? (
      <a
        href={getPageUrl(safeCurrentPage - 1)}
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border bg-card text-sm font-medium hover:bg-muted transition-colors"
        aria-label="Previous page"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Previous
      </a>
    ) : (
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border bg-muted text-sm font-medium text-muted-foreground cursor-not-allowed" aria-disabled="true">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Previous
      </span>
    )}
    
    {/* Page Numbers */}
    <div class="hidden sm:flex items-center gap-1">
      {pageNumbers.map((page, index) => (
        page === '...' ? (
          <span key={`ellipsis-${index}`} class="px-3 py-2 text-muted-foreground">...</span>
        ) : (
          <a
            key={`page-${page}`}
            href={getPageUrl(page as number)}
            class={`inline-flex items-center justify-center w-10 h-10 rounded-lg text-sm font-medium transition-colors ${
              page === safeCurrentPage
                ? 'bg-primary text-primary-foreground'
                : 'bg-card text-foreground hover:bg-muted'
            }`}
            aria-current={page === safeCurrentPage ? 'page' : undefined}
          >
            {page}
          </a>
        )
      ))}
    </div>
    
    {/* Mobile: Current page indicator */}
    <span class="sm:hidden px-3 py-2 text-sm text-muted-foreground">
      {safeCurrentPage} / {totalPages}
    </span>
    
    {/* Next Button */}
    {hasNext ? (
      <a
        href={getPageUrl(safeCurrentPage + 1)}
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border bg-card text-sm font-medium hover:bg-muted transition-colors"
        aria-label="Next page"
      >
        Next
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    ) : (
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border bg-muted text-sm font-medium text-muted-foreground cursor-not-allowed" aria-disabled="true">
        Next
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    )}
  </nav>
)}