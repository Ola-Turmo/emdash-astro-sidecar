---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, category, tags, featuredImage, excerpt, schemaType } = post.data;

const authorData = post.data.author;
const categoryData = post.data.category;
---

<BaseLayout
  title={title}
  description={excerpt || description}
  ogImage={featuredImage?.src}
  pubDate={pubDate}
  author={typeof authorData === 'object' ? authorData.name : authorData}
  schemaType={schemaType}
>
  <Header />
  
  <main class="max-w-3xl mx-auto px-4 py-8">
    <article>
      <!-- Featured image -->
      {featuredImage && (
        <figure class="mb-8">
          <img
            src={featuredImage.src}
            alt={featuredImage.alt}
            class="w-full h-auto rounded-xl"
            loading="eager"
          />
        </figure>
      )}
      
      <!-- Header -->
      <header class="mb-8">
        <!-- Category -->
        <a
          href={`/category/${categoryData.slug}`}
          class="inline-block text-sm font-medium text-blue-600 hover:text-blue-700 mb-4"
        >
          {typeof categoryData === 'object' ? categoryData.name : categoryData}
        </a>
        
        <!-- Title -->
        <h1 class="text-4xl font-bold text-neutral-900 mb-4 leading-tight">
          {title}
        </h1>
        
        <!-- Meta -->
        <div class="flex items-center gap-4 text-sm text-neutral-500">
          <time datetime={pubDate.toISOString()}>
            {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {updatedDate && (
            <span>Updated <time datetime={updatedDate.toISOString()}>{updatedDate.toLocaleDateString()}</time></span>
          )}
        </div>
      </header>
      
      <!-- Content -->
      <div class="prose prose-neutral prose-lg max-w-none">
        <slot />
      </div>
      
      <!-- Tags -->
      {tags && tags.length > 0 && (
        <footer class="mt-8 pt-8 border-t border-neutral-200">
          <div class="flex flex-wrap gap-2">
            {tags.map((tag: string) => (
              <a
                href={`/tag/${tag}`}
                class="px-3 py-1 text-sm bg-neutral-100 text-neutral-700 rounded-full hover:bg-neutral-200 transition-colors"
              >
                #{tag}
              </a>
            ))}
          </div>
        </footer>
      )}
    </article>
  </main>
  
  <Footer />
</BaseLayout>
