---
import { getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BaseLayout from './BaseLayout.astro';
import {
  MAIN_SITE_NAME,
  PRIMARY_CTA,
  SECONDARY_CTA,
  SHELL_COPY,
  categoryPath,
} from '../consts';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, category, tags, featuredImage, excerpt, schemaType } = post.data;

const authorId = typeof author === 'string' ? author : ('id' in author ? author.id : author.slug);
const categoryId = typeof category === 'string' ? category : ('id' in category ? category.id : category.slug);
const authorEntry = authorId ? await getEntry('authors', authorId) : undefined;
const categoryEntry = categoryId ? await getEntry('categories', categoryId) : undefined;
const authorName = authorEntry?.data.name ?? authorId ?? MAIN_SITE_NAME;
const categoryName = categoryEntry?.data.name ?? categoryId ?? 'Artikkel';
const categorySlug = categoryEntry?.slug ?? categoryId ?? '';
---

<BaseLayout
  title={title}
  description={excerpt || description}
  ogImage={featuredImage?.src}
  pubDate={pubDate}
  author={authorName}
  schemaType={schemaType}
>
  <Header />

  <main class="mx-auto max-w-5xl px-3 py-8 sm:px-4 md:py-14">
    <article>
      <div class="mx-auto max-w-3xl">
        <a href={categoryPath(categorySlug)} class="eyebrow inline-block">
          {categoryName}
        </a>
        <h1 class="display-title mt-4 text-4xl font-black leading-[1.05] text-slate-950 md:text-6xl">
          {title}
        </h1>
        <p class="mt-5 text-lg leading-8 text-slate-600">{excerpt || description}</p>
        <div class="mt-6 flex flex-wrap items-center gap-4 text-sm font-semibold text-slate-500">
          <time datetime={pubDate.toISOString()}>{pubDate.toLocaleDateString('nb-NO', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          <span>{authorName}</span>
          {updatedDate && (
            <span>Oppdatert <time datetime={updatedDate.toISOString()}>{updatedDate.toLocaleDateString('nb-NO')}</time></span>
          )}
        </div>
      </div>

      {featuredImage && (
        <figure class="shell-card mx-auto mt-10 max-w-4xl overflow-hidden p-3">
          <img
            src={featuredImage.src}
            alt={featuredImage.alt}
            class="h-auto w-full rounded-[1.35rem]"
            loading="eager"
          />
        </figure>
      )}

      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-[minmax(0,1fr),18rem]">
        <div class="shell-card overflow-hidden p-4 sm:p-5 md:p-10">
          <div class="article-prose prose prose-lg max-w-none prose-headings:scroll-mt-28">
            <slot />
          </div>

          {tags && tags.length > 0 && (
            <footer class="mt-10 border-t border-slate-200/80 pt-8">
              <div class="flex flex-wrap gap-2">
                {tags.map((tag: string) => (
                  <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm font-semibold text-slate-700">
                    #{tag}
                  </span>
                ))}
              </div>
            </footer>
          )}
        </div>

        <aside class="space-y-5">
          <div class="shell-card p-4 sm:p-5">
            <p class="eyebrow">{SHELL_COPY.articleNextStepEyebrow}</p>
            <p class="mt-3 text-sm leading-7 text-slate-600">
              {SHELL_COPY.articleNextStepText}
            </p>
            <div class="mt-4 flex flex-col gap-3">
              <a href={PRIMARY_CTA.href} class="cta-primary text-sm">{PRIMARY_CTA.label}</a>
              <a href={SECONDARY_CTA.href} class="cta-secondary text-sm">{SECONDARY_CTA.label}</a>
            </div>
          </div>

          <div class="shell-card p-4 sm:p-5">
            <p class="eyebrow">Om artikkelen</p>
            <dl class="mt-4 space-y-3 text-sm">
              <div>
                <dt class="font-bold text-slate-900">Kategori</dt>
                <dd class="text-slate-600">{categoryName}</dd>
              </div>
              <div>
                <dt class="font-bold text-slate-900">Forfatter</dt>
                <dd class="text-slate-600">{authorName}</dd>
              </div>
              <div>
                <dt class="font-bold text-slate-900">Formål</dt>
                <dd class="text-slate-600">{SHELL_COPY.articleAboutPurpose}</dd>
              </div>
            </dl>
          </div>
        </aside>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>
