---
import { getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BaseLayout from './BaseLayout.astro';
import { generateArticleJsonLd, generateBreadcrumbJsonLd } from '../lib/seo';
import {
  MAIN_SITE_NAME,
  PRIMARY_CTA,
  SECONDARY_CTA,
  SHELL_COPY,
  SITE_NAME,
  SITE_URL,
  categoryPath,
} from '../consts';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, category, tags, featuredImage, excerpt, schemaType } = post.data;

const authorId = typeof author === 'string' ? author : ('id' in author ? author.id : author.slug);
const categoryId = typeof category === 'string' ? category : ('id' in category ? category.id : category.slug);
const authorEntry = authorId ? await getEntry('authors', authorId) : undefined;
const categoryEntry = categoryId ? await getEntry('categories', categoryId) : undefined;
const authorName = authorEntry?.data.name ?? authorId ?? MAIN_SITE_NAME;
const categoryName = categoryEntry?.data.name ?? categoryId ?? 'Article';
const categorySlug = categoryEntry?.slug ?? categoryId ?? '';
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).href;
const categoryUrl = new URL(categoryPath(categorySlug).replace(/^\//u, ''), `${SITE_URL}/`).toString();
const jsonLdScripts = [
  generateBreadcrumbJsonLd([
    { name: SITE_NAME, url: SITE_URL },
    { name: categoryName, url: categoryUrl },
    { name: title, url: canonicalUrl },
  ]),
  generateArticleJsonLd({
    title,
    description: excerpt || description,
    url: canonicalUrl,
    ogImage: featuredImage?.src,
    pubDate,
    updatedDate,
    author: authorName,
    schemaType,
  }),
];
---

<BaseLayout
  title={title}
  description={excerpt || description}
  ogImage={featuredImage?.src}
  canonicalUrl={canonicalUrl}
  pubDate={pubDate}
  updatedDate={updatedDate}
  author={authorName}
  schemaType={schemaType}
  jsonLdScripts={jsonLdScripts}
>
  <Header />

  <main class="mx-auto max-w-5xl px-4 pt-[6rem] pb-12 md:pt-24 md:pb-20">
    <article>
      <div class="mx-auto max-w-3xl reveal">
        <a href={categoryPath(categorySlug)} class="eyebrow inline-block hover:text-[var(--color-accent-deep)]">
          {categoryName}
        </a>
        <h1 class="display-title mt-4 text-[2rem] font-bold leading-[1.08] tracking-tight text-[var(--color-ink)] md:text-[2.75rem]">
          {title}
        </h1>
        <p class="mt-5 text-[1.0625rem] leading-8 text-[var(--color-muted)]">{excerpt || description}</p>
        <div class="mt-6 flex flex-wrap items-center gap-4 text-sm text-[var(--color-muted)]">
          <time datetime={pubDate.toISOString()} class="font-mono text-xs">{pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          <span>{authorName}</span>
          {updatedDate && (
            <span>Updated <time datetime={updatedDate.toISOString()}>{updatedDate.toLocaleDateString('en-US')}</time></span>
          )}
        </div>
      </div>

      {featuredImage && (
        <figure class="mx-auto mt-10 max-w-4xl overflow-hidden rounded-lg border border-[var(--color-border)] reveal">
          <img
            src={featuredImage.src}
            alt={featuredImage.alt}
            class="h-auto w-full"
            loading="eager"
          />
        </figure>
      )}

      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-[minmax(0,1fr),16rem]">
        <div class="shell-card overflow-hidden p-6 sm:p-8 md:p-10 reveal">
          <div class="article-prose prose prose-lg max-w-none prose-headings:scroll-mt-28">
            <slot />
          </div>

          {tags && tags.length > 0 && (
            <footer class="mt-10 border-t border-[var(--color-border)] pt-6">
              <div class="flex flex-wrap gap-2">
                {tags.map((tag: string) => (
                  <span class="rounded-md border border-[var(--color-border)] bg-[var(--color-canvas)] px-2.5 py-0.5 text-xs font-medium text-[var(--color-muted)]">
                    #{tag}
                  </span>
                ))}
              </div>
            </footer>
          )}
        </div>

        <aside class="space-y-5 reveal reveal-delay-2">
          <div class="shell-card p-4 sm:p-5">
            <p class="eyebrow">{SHELL_COPY.articleNextStepEyebrow}</p>
            <p class="mt-3 text-sm leading-7 text-[var(--color-muted)]">
              {SHELL_COPY.articleNextStepText}
            </p>
            <div class="mt-4 flex flex-col gap-2.5">
              <a href={PRIMARY_CTA.href} class="cta-primary !text-sm">{PRIMARY_CTA.label}</a>
              <a href={SECONDARY_CTA.href} class="cta-secondary !text-sm">{SECONDARY_CTA.label}</a>
            </div>
          </div>

          <div class="shell-card p-4 sm:p-5">
            <p class="eyebrow">{SHELL_COPY.contentMeta.articleMetaEyebrow}</p>
            <dl class="mt-4 space-y-2.5 text-sm">
              <div>
                <dt class="font-medium text-[var(--color-ink)]">{SHELL_COPY.contentMeta.articleMetaCategoryLabel}</dt>
                <dd class="text-[var(--color-muted)]">{categoryName}</dd>
              </div>
              <div>
                <dt class="font-medium text-[var(--color-ink)]">{SHELL_COPY.contentMeta.articleMetaAuthorLabel}</dt>
                <dd class="text-[var(--color-muted)]">{authorName}</dd>
              </div>
              <div>
                <dt class="font-medium text-[var(--color-ink)]">{SHELL_COPY.contentMeta.articleMetaPurposeLabel}</dt>
                <dd class="text-[var(--color-muted)]">{SHELL_COPY.articleAboutPurpose}</dd>
              </div>
            </dl>
          </div>
        </aside>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>