---
import '../styles/global.css';
import rumClientScript from '../scripts/rum-client.inline.js?raw';
import {
  DEFAULT_OG_IMAGE,
  MAIN_SITE_NAME,
  MAIN_SITE_URL,
  ACTIVE_CONCEPT_KEY,
  ACTIVE_SITE_KEY,
  BLOG_BASE_PATH,
  RUM_ENDPOINT,
  SITE_DESCRIPTION,
  SITE_LANGUAGE,
  SITE_LOCALE,
  SITE_NAME,
  SITE_URL,
  SUPPORT_EMAIL,
} from '../consts';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
  schemaType?: string;
  jsonLdScripts?: string[];
  breadcrumbItems?: { name: string; url: string }[];
}

const {
  title,
  description = SITE_DESCRIPTION,
  ogImage = DEFAULT_OG_IMAGE,
  canonicalUrl,
  pubDate,
  updatedDate,
  author,
  schemaType = 'BlogPosting',
  jsonLdScripts = [],
  breadcrumbItems = [],
} = Astro.props;

const fullTitle = title === SITE_NAME ? title : `${title} | ${SITE_NAME}`;
const canonical = canonicalUrl || new URL(Astro.url.pathname, Astro.url.origin).href;
const articleSchemaTypes = new Set(['Article', 'BlogPosting', 'TechArticle', 'HowTo']);
const ogType = articleSchemaTypes.has(schemaType) ? 'article' : 'website';

const organizationSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: MAIN_SITE_NAME,
  url: MAIN_SITE_URL,
  email: SUPPORT_EMAIL,
  sameAs: [MAIN_SITE_URL],
  logo: {
    '@type': 'ImageObject',
    url: `${MAIN_SITE_URL}/favicon.svg`,
  },
});

const websiteSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: SITE_URL,
  inLanguage: SITE_LOCALE,
  publisher: {
    '@type': 'Organization',
    name: MAIN_SITE_NAME,
    url: MAIN_SITE_URL,
  },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${SITE_URL}/blog?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
});

const softwareAppSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Visibility.help',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Any',
  url: SITE_URL,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    ratingCount: '124',
  },
});

const breadcrumbSchema = breadcrumbItems.length > 0
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
        ...breadcrumbItems.map((item, index) => ({
          '@type': 'ListItem',
          position: index + 2,
          name: item.name,
          item: item.url,
        })),
      ],
    })
  : null;

const webPageSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: canonical,
  inLanguage: SITE_LOCALE,
  datePublished: pubDate?.toISOString(),
  dateModified: (updatedDate || pubDate)?.toISOString(),
  author: author
    ? { '@type': 'Person', name: author }
    : { '@type': 'Organization', name: MAIN_SITE_NAME },
  publisher: {
    '@type': 'Organization',
    name: MAIN_SITE_NAME,
    url: MAIN_SITE_URL,
  },
  isPartOf: {
    '@type': 'WebSite',
    name: SITE_NAME,
    url: SITE_URL,
  },
});

const rumConfigScript = JSON.stringify({
  endpoint: RUM_ENDPOINT,
  siteKey: ACTIVE_SITE_KEY,
  conceptKey: ACTIVE_CONCEPT_KEY,
  basePath: BLOG_BASE_PATH,
});
---

<!doctype html>
<html lang={SITE_LANGUAGE}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0f172a" />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="author" content={author || MAIN_SITE_NAME} />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content={SITE_LOCALE.replace('-', '_')} />
    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    {author && <meta property="article:author" content={author} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Font Preloads -->
    <link rel="preload" href="/fonts/geist-sans.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/playfair-display.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Resource Hints -->
    <link rel="preconnect" href="https://visibility.help" />
    <link rel="dns-prefetch" href="https://emdash-metrics-worker.ola-turmo.workers.dev" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{fullTitle}</title>

    <!-- Structured Data -->
    <script is:inline type="application/ld+json" set:html={organizationSchema} />
    <script is:inline type="application/ld+json" set:html={websiteSchema} />
    <script is:inline type="application/ld+json" set:html={softwareAppSchema} />
    <script is:inline type="application/ld+json" set:html={webPageSchema} />
    {breadcrumbSchema && <script is:inline type="application/ld+json" set:html={breadcrumbSchema} />}
    {jsonLdScripts.map((script) => <script is:inline type="application/ld+json" set:html={script} />)}
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.contains-task-list input[type="checkbox"]').forEach(function(cb) {
          if (!cb.getAttribute('aria-label')) cb.setAttribute('aria-label', 'Task item');
        });
      });
    </script>
  </head>
  <body class="antialiased">
    <slot />
    <script is:inline set:html={`window.__EMDASH_RUM__ = ${rumConfigScript};`} />
    <script is:inline set:html={rumClientScript} />
    <script is:inline>
      // Scroll reveal - IntersectionObserver based, no scroll event listeners
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));
    </script>
  </body>
</html>