---
import '../styles/global.css';
import rumClientScript from '../scripts/rum-client.inline.js?raw';
import {
  DEFAULT_OG_IMAGE,
  MAIN_SITE_NAME,
  MAIN_SITE_URL,
  ACTIVE_CONCEPT_KEY,
  ACTIVE_SITE_KEY,
  BLOG_BASE_PATH,
  RUM_ENDPOINT,
  blogPath,
  SITE_DESCRIPTION,
  SITE_LANGUAGE,
  SITE_LOCALE,
  SITE_NAME,
  SITE_URL,
  SUPPORT_EMAIL,
} from '../consts';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
  schemaType?: string;
  jsonLdScripts?: string[];
}

const {
  title,
  description = SITE_DESCRIPTION,
  ogImage = DEFAULT_OG_IMAGE,
  canonicalUrl,
  pubDate,
  updatedDate,
  author,
  schemaType = 'BlogPosting',
  jsonLdScripts = [],
} = Astro.props;

const fullTitle = title === SITE_NAME ? title : `${title} | ${SITE_NAME}`;
const canonical = canonicalUrl || new URL(Astro.url.pathname, SITE_URL).href;
const articleSchemaTypes = new Set(['Article', 'BlogPosting', 'TechArticle', 'HowTo']);
const ogType = articleSchemaTypes.has(schemaType) ? 'article' : 'website';

const organizationSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: MAIN_SITE_NAME,
  url: MAIN_SITE_URL,
  email: SUPPORT_EMAIL,
  sameAs: [MAIN_SITE_URL],
});

const websiteSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: SITE_URL,
  inLanguage: SITE_LOCALE,
  publisher: {
    '@type': 'Organization',
    name: MAIN_SITE_NAME,
    url: MAIN_SITE_URL,
  },
});

const rumConfigScript = JSON.stringify({
  endpoint: RUM_ENDPOINT,
  siteKey: ACTIVE_SITE_KEY,
  conceptKey: ACTIVE_CONCEPT_KEY,
  basePath: BLOG_BASE_PATH,
});
---

<!doctype html>
<html lang={SITE_LANGUAGE}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#115E59" />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="author" content={author || MAIN_SITE_NAME} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content={SITE_LOCALE.replace('-', '_')} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    {author && <meta property="article:author" content={author} />}
    <title>{fullTitle}</title>
    <link rel="preload" href={blogPath('/fonts/manrope.woff2')} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={blogPath('/fonts/playfair-display.woff2')} as="font" type="font/woff2" crossorigin />
    <script is:inline type="application/ld+json" set:html={organizationSchema} />
    <script is:inline type="application/ld+json" set:html={websiteSchema} />
    {jsonLdScripts.map((script) => <script is:inline type="application/ld+json" set:html={script} />)}
  </head>
  <body class="antialiased">
    <slot />
    <script is:inline set:html={`window.__EMDASH_RUM__ = ${rumConfigScript};`} />
    <script is:inline set:html={rumClientScript} />
  </body>
</html>
