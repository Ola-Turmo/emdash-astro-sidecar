---
import '../styles/global.css';
import {
  DEFAULT_OG_IMAGE,
  MAIN_SITE_NAME,
  MAIN_SITE_URL,
  SITE_DESCRIPTION,
  SITE_LANGUAGE,
  SITE_LOCALE,
  SITE_NAME,
  SITE_URL,
  SUPPORT_EMAIL,
} from '../consts';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  pubDate?: Date;
  author?: string;
  schemaType?: string;
}

const {
  title,
  description = SITE_DESCRIPTION,
  ogImage = DEFAULT_OG_IMAGE,
  canonicalUrl,
  pubDate,
  author,
  schemaType = 'BlogPosting',
} = Astro.props;

const fullTitle = title === SITE_NAME ? title : `${title} | ${SITE_NAME}`;
const canonical = canonicalUrl || new URL(Astro.url.pathname, SITE_URL).href;

const organizationSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: MAIN_SITE_NAME,
  url: MAIN_SITE_URL,
  email: SUPPORT_EMAIL,
  sameAs: [MAIN_SITE_URL],
});

const websiteSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: SITE_URL,
  inLanguage: SITE_LOCALE,
  publisher: {
    '@type': 'Organization',
    name: MAIN_SITE_NAME,
    url: MAIN_SITE_URL,
  },
});
---

<!doctype html>
<html lang={SITE_LANGUAGE}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#115E59" />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="author" content={author || MAIN_SITE_NAME} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={schemaType === 'BlogPosting' ? 'article' : 'website'} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content={SITE_LOCALE.replace('-', '_')} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {author && <meta property="article:author" content={author} />}
    <title>{fullTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet" />
    <script is:inline type="application/ld+json" set:html={organizationSchema} />
    <script is:inline type="application/ld+json" set:html={websiteSchema} />
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
