---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  category: CollectionEntry<'categories'>;
  posts: CollectionEntry<'blog'>[];
}

const { category, posts } = Astro.props;
const { name, description } = category.data;
---

<BaseLayout title={name} description={description}>
  <Header />
  
  <main>
    <!-- Hero -->
    <section class="bg-neutral-50 py-16">
      <div class="max-w-4xl mx-auto px-4">
        <span class="text-sm font-medium text-blue-600 uppercase tracking-wider">Category</span>
        <h1 class="text-4xl font-bold text-neutral-900 mt-2">{name}</h1>
        {description && <p class="text-xl text-neutral-600 mt-4">{description}</p>}
      </div>
    </section>
    
    <!-- Posts grid -->
    <section class="max-w-4xl mx-auto px-4 py-12">
      <div class="grid gap-8">
        {posts.map(post => (
          <article class="border border-neutral-200 rounded-xl p-6 hover:shadow-lg transition-shadow">
            <h2 class="text-2xl font-bold mb-2">
              <a href={`/blog/${post.slug}`} class="hover:text-blue-600 transition-colors">
                {post.data.title}
              </a>
            </h2>
            <p class="text-neutral-600 mb-4">{post.data.excerpt}</p>
            <div class="text-sm text-neutral-500">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString()}
              </time>
            </div>
          </article>
        ))}
      </div>
      
      {posts.length === 0 && (
        <p class="text-center text-neutral-500 py-12">No posts in this category yet.</p>
      )}
    </section>
  </main>
  
  <Footer />
</BaseLayout>
