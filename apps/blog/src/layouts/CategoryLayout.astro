---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { CollectionEntry } from 'astro:content';
import { blogPath } from '../consts';

interface Props {
  category: CollectionEntry<'categories'>;
  posts: CollectionEntry<'blog'>[];
}

const { category, posts } = Astro.props;
const { name, description } = category.data;
---

<BaseLayout title={name} description={description}>
  <Header />

  <main>
    <section class="px-4 py-16">
      <div class="mx-auto max-w-6xl">
        <span class="eyebrow">Kategori</span>
        <h1 class="display-title mt-3 text-4xl font-bold text-slate-950 md:text-5xl">{name}</h1>
        {description && <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-600">{description}</p>}
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-12">
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {posts.map((post) => (
          <div class="shell-card p-6">
            <h2 class="text-2xl font-extrabold tracking-tight text-slate-900">
              <a href={blogPath(`/blog/${post.slug}`)} class="transition-colors hover:text-teal-800">
                {post.data.title}
              </a>
            </h2>
            <p class="mt-3 text-sm leading-7 text-slate-600">{post.data.excerpt}</p>
            <div class="mt-5 text-sm font-semibold text-slate-500">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('nb-NO')}
              </time>
            </div>
          </div>
        ))}
      </div>

      {posts.length === 0 && (
        <p class="py-12 text-center text-slate-500">Ingen artikler i denne kategorien ennå.</p>
      )}
    </section>
  </main>

  <Footer />
</BaseLayout>
