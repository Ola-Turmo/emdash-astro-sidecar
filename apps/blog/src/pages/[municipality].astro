---
import type { CollectionEntry } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import {
  ACTIVE_CONCEPT_KEY,
  CONCEPT_PAGE_STRUCTURE,
  PRIMARY_CTA,
  SECONDARY_CTA,
  SHELL_COPY,
  blogPath,
} from '../consts';
import { deriveMunicipalityView } from '../lib/municipality-view';
import { getPublishedMunicipalPages } from '../lib/published-content';
import BaseLayout from '../layouts/BaseLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  if (ACTIVE_CONCEPT_KEY !== 'kommune' || CONCEPT_PAGE_STRUCTURE !== 'directory') {
    return [];
  }

  const pages = await getPublishedMunicipalPages();
  return pages.map((page: CollectionEntry<'municipalPages'>) => ({
    params: {
      municipality: page.slug,
    },
    props: {
      page,
    },
  }));
};

const { page } = Astro.props as { page: CollectionEntry<'municipalPages'> };
const {
  municipality,
  municipalityNumber,
  county,
  languageForm,
  domain,
  municipalitySiteUrl,
  alcoholPolicyPlanUrl,
  formsUrl,
  publicRecordsUrl,
  municipalitySitePlatform,
  heroImage,
  siteLastUpdated,
  relatedGuideLinks,
  sourceRepo,
  sourceLastChecked,
  title,
  description,
  pubDate,
  updatedDate,
} = page.data;
const municipalityView = deriveMunicipalityView(page.data);
const heroImageSrc = heroImage?.src ? blogPath(heroImage.src.replace(/\.png$/i, '.webp')) : null;
---

<BaseLayout title={title} description={description} pubDate={pubDate}>
  <Header />

  <main class="mx-auto max-w-6xl px-3 py-8 sm:px-4 md:py-14">
    <article>
      <div class="mx-auto max-w-4xl">
        <p class="eyebrow">{SHELL_COPY.articleContextLabel}</p>
        <h1 class="display-title mt-4 text-4xl font-black leading-[1.05] text-slate-950 md:text-6xl">
          {title}
        </h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">{description}</p>
        <div class="mt-6 flex flex-wrap items-center gap-4 text-sm font-semibold text-slate-500">
          <span>{municipality}</span>
          {county && <span>{county}</span>}
          {municipalityNumber && <span>Kommune {municipalityNumber}</span>}
          <time datetime={pubDate.toISOString()}>
            {pubDate.toLocaleDateString('nb-NO', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {updatedDate && (
            <span>
              Oppdatert <time datetime={updatedDate.toISOString()}>{updatedDate.toLocaleDateString('nb-NO')}</time>
            </span>
          )}
        </div>
      </div>

      <div class="mx-auto mt-10 grid max-w-6xl gap-8 lg:grid-cols-[minmax(0,1fr),20rem]">
        <div class="space-y-6">
          {heroImage && (
            <section class="shell-card overflow-hidden p-2">
              <img
                src={heroImageSrc}
                alt={heroImage.alt}
                class="h-[240px] w-full rounded-[1.35rem] object-cover sm:h-[320px]"
                loading="eager"
              />
            </section>
          )}

          <section class="shell-card overflow-hidden p-5 sm:p-6 md:p-10">
            <p class="text-base leading-8 text-slate-700">{municipalityView.lead}</p>
            {municipalityView.facts.length > 0 && (
              <div class="mt-8 grid gap-4 md:grid-cols-2">
                {municipalityView.facts.map((fact) => (
                  <article class="rounded-[1.35rem] border border-slate-200/80 bg-white/90 p-4">
                    <p class="text-sm leading-7 text-slate-700">{fact}</p>
                  </article>
                ))}
              </div>
            )}
          </section>

          {municipalityView.timeline.length > 0 && (
            <section class="shell-card p-5 sm:p-6">
              <p class="eyebrow">Tidslinje for lokale alkoholregler</p>
              <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                {municipalityView.timeline.map((entry) => (
                  <article class="rounded-[1.35rem] border border-slate-200/80 bg-white/90 p-4">
                    <div class="flex items-center justify-between gap-3">
                      <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">
                        {entry.kind === 'sales' ? 'Salg' : entry.kind === 'serving' ? 'Skjenking' : 'Åpning'}
                      </p>
                    </div>
                    <h2 class="mt-3 text-lg font-bold text-slate-950">{entry.label}</h2>
                    {(entry.days || entry.startTime || entry.endTime) && (
                      <p class="mt-3 text-sm font-semibold text-teal-700">
                        {[entry.days, entry.startTime && entry.endTime ? `${entry.startTime}–${entry.endTime}` : entry.endTime ? `til ${entry.endTime}` : entry.startTime ? `fra ${entry.startTime}` : '']
                          .filter(Boolean)
                          .join(' · ')}
                      </p>
                    )}
                    <p class="mt-3 text-sm leading-7 text-slate-600">{entry.note}</p>
                  </article>
                ))}
              </div>
            </section>
          )}

          {municipalityView.salesNote && (
            <section class="shell-card border border-amber-200/80 bg-amber-50/60 p-5 sm:p-6">
              <p class="eyebrow text-amber-700">Salg av alkohol</p>
              <p class="mt-3 text-sm leading-7 text-slate-700">{municipalityView.salesNote}</p>
            </section>
          )}

          {municipalityView.highlights.length > 0 && (
            <section class="shell-card p-5 sm:p-6">
              <p class="eyebrow">Dette skiller {municipality} fra andre kommuner</p>
              <div class="mt-4 grid gap-4 md:grid-cols-2">
                {municipalityView.highlights.map((highlight) => (
                  <article class="rounded-[1.35rem] border border-slate-200/80 bg-white/90 p-4">
                    <p class="text-sm leading-7 text-slate-700">{highlight}</p>
                  </article>
                ))}
              </div>
            </section>
          )}

          {municipalityView.curatedLinks.length > 0 && (
            <section class="shell-card p-5 sm:p-6">
              <p class="eyebrow">Kommunale sider du bør åpne først</p>
              <div class="mt-4 grid gap-4 md:grid-cols-2">
                {municipalityView.curatedLinks.map((link) => (
                  <article class="rounded-[1.35rem] border border-slate-200/80 bg-white/90 p-4">
                    <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">{link.displayLabel}</p>
                    <p class="mt-3 text-sm leading-7 text-slate-600">{link.displayNote}</p>
                    <p class="mt-4 text-sm font-semibold text-teal-700">
                      <a href={link.url}>Åpne kommunesiden</a>
                    </p>
                  </article>
                ))}
              </div>
            </section>
          )}

          {municipalityView.checklist.length > 0 && (
            <section class="shell-card p-5 sm:p-6">
              <p class="eyebrow">Dette bør du gjøre før du søker eller åpner</p>
              <ul class="mt-4 space-y-3 text-sm leading-7 text-slate-600">
                {municipalityView.checklist.map((item) => (
                  <li class="flex gap-3">
                    <span class="mt-2 h-2 w-2 rounded-full bg-teal-600"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {municipalityView.usefulSources.length >= 2 && (
            <section class="shell-card p-5 sm:p-6">
              <p class="eyebrow">Offisielle kilder med nyttig lokal forklaring</p>
              <div class="mt-4 grid gap-4 md:grid-cols-2">
                {municipalityView.usefulSources.map((source) => (
                  <article class="rounded-[1.35rem] border border-slate-200/80 bg-white/90 p-4">
                    <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">{source.label}</p>
                    {source.title && <h2 class="mt-2 text-lg font-bold text-slate-950">{source.title}</h2>}
                    {source.summary && <p class="mt-2 text-sm leading-7 text-slate-600">{source.summary}</p>}
                    <p class="mt-4 text-sm font-semibold text-teal-700">
                      <a href={source.url}>Åpne kilden</a>
                    </p>
                  </article>
                ))}
              </div>
            </section>
          )}
        </div>

        <aside class="space-y-5">
          <div class="shell-card p-5">
            <p class="eyebrow">{SHELL_COPY.articleNextStepEyebrow}</p>
            <p class="mt-3 text-sm leading-7 text-slate-600">{SHELL_COPY.articleNextStepText}</p>
            <div class="mt-4 flex flex-col gap-3">
              <a href={PRIMARY_CTA.href} class="cta-primary text-sm">{PRIMARY_CTA.label}</a>
              <a href={SECONDARY_CTA.href} class="cta-secondary text-sm">{SECONDARY_CTA.label}</a>
            </div>
          </div>

          <div class="shell-card p-5">
            <p class="eyebrow">Kort oppsummert</p>
            <dl class="mt-4 space-y-3 text-sm">
              <div>
                <dt class="font-bold text-slate-900">Kommune</dt>
                <dd class="text-slate-600">{municipality}</dd>
              </div>
              {county && (
                <div>
                  <dt class="font-bold text-slate-900">Fylke</dt>
                  <dd class="text-slate-600">{county}</dd>
                </div>
              )}
              {municipalityView.summaryRows.map((row) => (
                <div>
                  <dt class="font-bold text-slate-900">{row.label}</dt>
                  <dd class="text-slate-600">{row.value}</dd>
                </div>
              ))}
              {siteLastUpdated?.value && (
                <div>
                  <dt class="font-bold text-slate-900">Sist oppdatert nettsted</dt>
                  <dd class="text-slate-600">{siteLastUpdated.value}</dd>
                </div>
              )}
            </dl>
          </div>

          {relatedGuideLinks.length > 0 && (
            <div class="shell-card p-5">
              <p class="eyebrow">Les mer på kurs.ing</p>
              <div class="mt-4 space-y-3 text-sm leading-7 text-slate-600">
                {relatedGuideLinks.map((link: (typeof relatedGuideLinks)[number]) => (
                  <p><a href={link.url}>{link.label}</a></p>
                ))}
              </div>
            </div>
          )}

          <div class="shell-card p-5">
            <p class="eyebrow">Kilder og kontrollpunkter</p>
            <div class="mt-4 space-y-3 text-sm leading-7 text-slate-600">
              {sourceRepo && <p><strong>Kilde:</strong> {sourceRepo}</p>}
              {sourceLastChecked && <p><strong>Sist kontrollert:</strong> {sourceLastChecked}</p>}
              {municipalitySiteUrl && (
                <p><strong>Kommunenettsted:</strong> <a href={municipalitySiteUrl}>{municipalitySiteUrl}</a></p>
              )}
              {formsUrl && <p><strong>Skjema:</strong> <a href={formsUrl}>{formsUrl}</a></p>}
              {publicRecordsUrl && <p><strong>Innsyn:</strong> <a href={publicRecordsUrl}>{publicRecordsUrl}</a></p>}
              {alcoholPolicyPlanUrl && <p><strong>Plan eller tider:</strong> <a href={alcoholPolicyPlanUrl}>{alcoholPolicyPlanUrl}</a></p>}
              {municipalitySitePlatform && <p><strong>Nettstedsplattform:</strong> {municipalitySitePlatform}</p>}
              {domain && <p><strong>Domene:</strong> {domain}</p>}
              {languageForm && <p><strong>Målform:</strong> {languageForm}</p>}
            </div>
          </div>
        </aside>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>
