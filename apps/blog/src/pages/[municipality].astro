---
import type { CollectionEntry } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import {
  ACTIVE_CONCEPT_KEY,
  CONCEPT_PAGE_STRUCTURE,
  PRIMARY_CTA,
  SECONDARY_CTA,
  SHELL_COPY,
} from '../consts';
import { getPublishedMunicipalPages } from '../lib/published-content';
import BaseLayout from '../layouts/BaseLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  if (ACTIVE_CONCEPT_KEY !== 'kommune' || CONCEPT_PAGE_STRUCTURE !== 'directory') {
    return [];
  }

  const pages = await getPublishedMunicipalPages();
  return pages.map((page: CollectionEntry<'municipalPages'>) => ({
    params: {
      municipality: page.slug,
    },
    props: {
      page,
    },
  }));
};

const { page } = Astro.props as { page: CollectionEntry<'municipalPages'> };
const { municipality, county, title, description, pubDate, updatedDate } = page.data;
const { Content } = await page.render();
---

<BaseLayout title={title} description={description} pubDate={pubDate}>
  <Header />

  <main class="mx-auto max-w-5xl px-4 py-10 md:py-14">
    <article>
      <div class="mx-auto max-w-3xl">
        <p class="eyebrow">{SHELL_COPY.articleContextLabel}</p>
        <h1 class="display-title mt-4 text-4xl font-black leading-[1.05] text-slate-950 md:text-6xl">
          {title}
        </h1>
        <p class="mt-5 text-lg leading-8 text-slate-600">{description}</p>
        <div class="mt-6 flex flex-wrap items-center gap-4 text-sm font-semibold text-slate-500">
          <span>{municipality}</span>
          {county && <span>{county}</span>}
          <time datetime={pubDate.toISOString()}>{pubDate.toLocaleDateString('nb-NO', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          {updatedDate && (
            <span>Oppdatert <time datetime={updatedDate.toISOString()}>{updatedDate.toLocaleDateString('nb-NO')}</time></span>
          )}
        </div>
      </div>

      <div class="mx-auto mt-10 grid max-w-5xl gap-8 lg:grid-cols-[minmax(0,1fr),18rem]">
        <div class="shell-card overflow-hidden p-6 md:p-10">
          <div class="article-prose prose prose-lg max-w-none prose-headings:scroll-mt-28">
            <Content />
          </div>
        </div>

        <aside class="space-y-5">
          <div class="shell-card p-5">
            <p class="eyebrow">{SHELL_COPY.articleNextStepEyebrow}</p>
            <p class="mt-3 text-sm leading-7 text-slate-600">
              {SHELL_COPY.articleNextStepText}
            </p>
            <div class="mt-4 flex flex-col gap-3">
              <a href={PRIMARY_CTA.href} class="cta-primary text-sm">{PRIMARY_CTA.label}</a>
              <a href={SECONDARY_CTA.href} class="cta-secondary text-sm">{SECONDARY_CTA.label}</a>
            </div>
          </div>

          <div class="shell-card p-5">
            <p class="eyebrow">Om siden</p>
            <dl class="mt-4 space-y-3 text-sm">
              <div>
                <dt class="font-bold text-slate-900">Kommune</dt>
                <dd class="text-slate-600">{municipality}</dd>
              </div>
              {county && (
                <div>
                  <dt class="font-bold text-slate-900">Fylke</dt>
                  <dd class="text-slate-600">{county}</dd>
                </div>
              )}
              <div>
                <dt class="font-bold text-slate-900">Formål</dt>
                <dd class="text-slate-600">{SHELL_COPY.articleAboutPurpose}</dd>
              </div>
            </dl>
          </div>
        </aside>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>
