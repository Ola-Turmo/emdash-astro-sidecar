---
import type { CollectionEntry } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import {
  ACTIVE_CONCEPT_KEY,
  CONCEPT_PAGE_STRUCTURE,
  PRIMARY_CTA,
  SECONDARY_CTA,
  SHELL_COPY,
  SITE_URL,
  blogPath,
} from '../consts';
import { deriveMunicipalityView } from '../lib/municipality-view';
import { getPublishedMunicipalPages } from '../lib/published-content';
import BaseLayout from '../layouts/BaseLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  if (ACTIVE_CONCEPT_KEY !== 'kommune' || CONCEPT_PAGE_STRUCTURE !== 'directory') {
    return [];
  }

  const pages = await getPublishedMunicipalPages();
  return pages.map((page: CollectionEntry<'municipalPages'>) => ({
    params: {
      municipality: page.slug,
    },
    props: {
      page,
    },
  }));
};

const { page } = Astro.props as { page: CollectionEntry<'municipalPages'> };
const {
  municipality,
  municipalityNumber,
  county,
  languageForm,
  domain,
  municipalitySiteUrl,
  alcoholPolicyPlanUrl,
  formsUrl,
  publicRecordsUrl,
  municipalitySitePlatform,
  heroImage,
  siteLastUpdated,
  relatedGuideLinks,
  sourceRepo,
  sourceLastChecked,
  title,
  description,
  pubDate,
  updatedDate,
} = page.data;
const municipalityView = deriveMunicipalityView(page.data);
const heroImageSrc = heroImage?.src ? blogPath(heroImage.src.replace(/\.png$/i, '.webp')) : null;
const ogImage = heroImageSrc ? new URL(heroImageSrc, SITE_URL).href : undefined;
---

<BaseLayout title={title} description={description} pubDate={pubDate} ogImage={ogImage}>
  <Header />

  <main class="mx-auto max-w-6xl px-3 py-8 sm:px-4 md:py-14">
    <article>
      <div class="mx-auto max-w-4xl reveal">
        <p class="eyebrow">{SHELL_COPY.articleContextLabel}</p>
        <h1 class="display-title mt-4 text-4xl font-bold leading-[1.05] text-[var(--ink)] md:text-6xl">
          {title}
        </h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-[var(--ink-secondary)]">{description}</p>
        <div class="mt-6 flex flex-wrap items-center gap-4 text-sm font-medium text-[var(--ink-tertiary)]">
          <span>{municipality}</span>
          {county && <span>{county}</span>}
          {municipalityNumber && <span>Kommune {municipalityNumber}</span>}
          <time datetime={pubDate.toISOString()}>
            {pubDate.toLocaleDateString('nb-NO', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {updatedDate && (
            <span>
              Oppdatert <time datetime={updatedDate.toISOString()}>{updatedDate.toLocaleDateString('nb-NO')}</time>
            </span>
          )}
        </div>
      </div>

      <div class="mx-auto mt-10 grid max-w-6xl gap-8 lg:grid-cols-[minmax(0,1fr),20rem]">
        <div class="space-y-6">
          {heroImage && (
            <section class="shell-card overflow-hidden p-2 reveal">
              <img
                src={heroImageSrc}
                alt={heroImage.alt}
                class="h-[240px] w-full rounded-xl object-cover sm:h-[320px]"
                loading="eager"
              />
            </section>
          )}

          <section class="shell-card overflow-hidden p-5 sm:p-6 md:p-10 reveal">
            <p class="text-base leading-8 text-[var(--ink-secondary)]">{municipalityView.lead}</p>
            {municipalityView.facts.length > 0 && (
              <div class="mt-8 grid gap-4 md:grid-cols-2">
                {municipalityView.facts.map((fact) => (
                  <article class="inner-card p-4">
                    <p class="text-sm leading-7 text-[var(--ink-secondary)]">{fact}</p>
                  </article>
                ))}
              </div>
            )}
          </section>

          {municipalityView.timeline.length > 0 && (
            <section class="shell-card p-5 sm:p-6 reveal">
              <p class="eyebrow">{SHELL_COPY.municipalityPage?.timelineEyebrow}</p>
              <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                {municipalityView.timeline.map((entry) => (
                  <article class="inner-card p-4">
                    <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--ink-tertiary)]">
                      {entry.kind === 'sales' ? 'Salg' : entry.kind === 'serving' ? 'Skjenking' : 'Åpning'}
                    </p>
                    <h2 class="mt-3 text-lg font-bold text-[var(--ink)]">{entry.label}</h2>
                    {(entry.days || entry.startTime || entry.endTime) && (
                      <p class="mt-3 text-sm font-medium text-[var(--accent)]">
                        {[entry.days, entry.startTime && entry.endTime ? `${entry.startTime}–${entry.endTime}` : entry.endTime ? `til ${entry.endTime}` : entry.startTime ? `fra ${entry.startTime}` : '']
                          .filter(Boolean)
                          .join(' · ')}
                      </p>
                    )}
                    <p class="mt-3 text-sm leading-7 text-[var(--ink-secondary)]">{entry.note}</p>
                  </article>
                ))}
              </div>
            </section>
          )}

          {municipalityView.salesNote && (
            <section class="shell-card border border-amber-200/80 bg-amber-50/60 p-5 sm:p-6 reveal">
              <p class="eyebrow text-amber-700">{SHELL_COPY.municipalityPage?.salesEyebrow}</p>
              <p class="mt-3 text-sm leading-7 text-[var(--ink-secondary)]">{municipalityView.salesNote}</p>
            </section>
          )}

          {municipalityView.highlights.length > 0 && (
            <section class="shell-card p-5 sm:p-6 reveal">
              <p class="eyebrow">{SHELL_COPY.municipalityPage?.highlightsEyebrowTemplate?.replace('{municipality}', municipality)}</p>
              <div class="mt-4 grid gap-4 md:grid-cols-2">
                {municipalityView.highlights.map((highlight) => (
                  <article class="inner-card p-4">
                    <p class="text-sm leading-7 text-[var(--ink-secondary)]">{highlight}</p>
                  </article>
                ))}
              </div>
            </section>
          )}

          {municipalityView.curatedLinks.length > 0 && (
            <section class="shell-card p-5 sm:p-6 reveal">
              <p class="eyebrow">{SHELL_COPY.municipalityPage?.curatedLinksEyebrow}</p>
              <div class="mt-4 grid gap-4 md:grid-cols-2">
                {municipalityView.curatedLinks.map((link) => (
                  <article class="inner-card p-4">
                    <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--ink-tertiary)]">{link.displayLabel}</p>
                    <p class="mt-3 text-sm leading-7 text-[var(--ink-secondary)]">{link.displayNote}</p>
                    <p class="mt-4 text-sm font-medium text-[var(--accent)]">
                      <a href={link.url}>{SHELL_COPY.municipalityPage?.curatedLinksActionLabel}</a>
                    </p>
                  </article>
                ))}
              </div>
            </section>
          )}

          {municipalityView.checklist.length > 0 && (
            <section class="shell-card p-5 sm:p-6 reveal">
              <p class="eyebrow">{SHELL_COPY.municipalityPage?.checklistEyebrow}</p>
              <ul class="mt-4 space-y-3 text-sm leading-7 text-[var(--ink-secondary)]">
                {municipalityView.checklist.map((item) => (
                  <li class="flex gap-3">
                    <span class="mt-2 h-2 w-2 rounded-full bg-[var(--accent)]"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {municipalityView.usefulSources.length >= 2 && (
            <section class="shell-card p-5 sm:p-6 reveal">
              <p class="eyebrow">{SHELL_COPY.municipalityPage?.usefulSourcesEyebrow}</p>
              <div class="mt-4 grid gap-4 md:grid-cols-2">
                {municipalityView.usefulSources.map((source) => (
                  <article class="inner-card p-4">
                    <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--ink-tertiary)]">{source.label}</p>
                    {source.title && <h2 class="mt-2 text-lg font-bold text-[var(--ink)]">{source.title}</h2>}
                    {source.summary && <p class="mt-2 text-sm leading-7 text-[var(--ink-secondary)]">{source.summary}</p>}
                    <p class="mt-4 text-sm font-medium text-[var(--accent)]">
                      <a href={source.url}>{SHELL_COPY.municipalityPage?.usefulSourcesActionLabel}</a>
                    </p>
                  </article>
                ))}
              </div>
            </section>
          )}
        </div>

        <aside class="space-y-5">
          <div class="shell-card p-5 reveal">
            <p class="eyebrow">{SHELL_COPY.articleNextStepEyebrow}</p>
            <p class="mt-3 text-sm leading-7 text-[var(--ink-secondary)]">{SHELL_COPY.articleNextStepText}</p>
            <div class="mt-4 flex flex-col gap-3">
              <a href={PRIMARY_CTA.href} class="cta-primary text-sm">{PRIMARY_CTA.label}</a>
              <a href={SECONDARY_CTA.href} class="cta-secondary text-sm">{SECONDARY_CTA.label}</a>
            </div>
          </div>

          <div class="shell-card p-5 reveal">
            <p class="eyebrow">{SHELL_COPY.municipalityPage?.summaryEyebrow}</p>
            <dl class="mt-4 space-y-3 text-sm">
              <div>
                <dt class="font-bold text-[var(--ink)]">{SHELL_COPY.municipalityPage?.summaryMunicipalityLabel}</dt>
                <dd class="text-[var(--ink-secondary)]">{municipality}</dd>
              </div>
              {county && (
                <div>
                  <dt class="font-bold text-[var(--ink)]">{SHELL_COPY.municipalityPage?.summaryCountyLabel}</dt>
                  <dd class="text-[var(--ink-secondary)]">{county}</dd>
                </div>
              )}
              {municipalityView.summaryRows.map((row) => (
                <div>
                  <dt class="font-bold text-[var(--ink)]">{row.label}</dt>
                  <dd class="text-[var(--ink-secondary)]">{row.value}</dd>
                </div>
              ))}
              {siteLastUpdated?.value && (
                <div>
                  <dt class="font-bold text-[var(--ink)]">{SHELL_COPY.municipalityPage?.summarySiteUpdatedLabel}</dt>
                  <dd class="text-[var(--ink-secondary)]">{siteLastUpdated.value}</dd>
                </div>
              )}
            </dl>
          </div>

          {relatedGuideLinks.length > 0 && (
            <div class="shell-card p-5 reveal">
              <p class="eyebrow">{SHELL_COPY.municipalityPage?.relatedGuidesEyebrow}</p>
              <div class="mt-4 space-y-3 text-sm leading-7 text-[var(--ink-secondary)]">
                {relatedGuideLinks.map((link: (typeof relatedGuideLinks)[number]) => (
                  <p><a href={link.url}>{link.label}</a></p>
                ))}
              </div>
            </div>
          )}

          <div class="shell-card p-5 reveal">
            <p class="eyebrow">{SHELL_COPY.municipalityPage?.sourcesEyebrow}</p>
            <div class="mt-4 space-y-3 text-sm leading-7 text-[var(--ink-secondary)]">
              {sourceRepo && <p><strong>{SHELL_COPY.municipalityPage?.sourceRepoLabel}:</strong> {sourceRepo}</p>}
              {sourceLastChecked && <p><strong>{SHELL_COPY.municipalityPage?.sourceLastCheckedLabel}:</strong> {sourceLastChecked}</p>}
              {municipalitySiteUrl && (
                <p><strong>{SHELL_COPY.municipalityPage?.sourceSiteLabel}:</strong> <a href={municipalitySiteUrl}>{municipalitySiteUrl}</a></p>
              )}
              {formsUrl && <p><strong>{SHELL_COPY.municipalityPage?.sourceFormsLabel}:</strong> <a href={formsUrl}>{formsUrl}</a></p>}
              {publicRecordsUrl && <p><strong>{SHELL_COPY.municipalityPage?.sourcePublicRecordsLabel}:</strong> <a href={publicRecordsUrl}>{publicRecordsUrl}</a></p>}
              {alcoholPolicyPlanUrl && <p><strong>{SHELL_COPY.municipalityPage?.sourcePolicyLabel}:</strong> <a href={alcoholPolicyPlanUrl}>{alcoholPolicyPlanUrl}</a></p>}
              {municipalitySitePlatform && <p><strong>{SHELL_COPY.municipalityPage?.sourcePlatformLabel}:</strong> {municipalitySitePlatform}</p>}
              {domain && <p><strong>{SHELL_COPY.municipalityPage?.sourceDomainLabel}:</strong> {domain}</p>}
              {languageForm && <p><strong>{SHELL_COPY.municipalityPage?.sourceLanguageLabel}:</strong> {languageForm}</p>}
            </div>
          </div>
        </aside>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>