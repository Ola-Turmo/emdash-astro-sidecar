---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { PRIMARY_CTA, SECONDARY_CTA, SHELL_COPY } from '../consts';

const title = 'About';
const description = 'Visibility was built by operators who believe AI search is the new discovery layer. We help brands become the sources that AI engines cite.';

const breadcrumbItems = [
  { name: 'About', url: 'https://visibility.help/about/' },
];

const aboutSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Visibility',
  description,
  url: 'https://visibility.help/about/',
  mainEntity: {
    '@type': 'Organization',
    name: 'Visibility',
    url: 'https://visibility.help',
    foundingDate: '2024',
    description: 'AI-powered SEO and GEO optimization platform built on Cloudflare.',
  },
});

const values = [
  { title: 'Citation, not traffic', desc: 'We optimize for AI citations. The metric that matters is whether language models name you as a source.' },
  { title: 'Infrastructure over hacks', desc: 'Structured data, semantic HTML, and proper crawler access. The stuff that compounds. No trickery.' },
  { title: 'Open by default', desc: 'Every tool we build works with publicly available standards. No lock-in, no secret sauce, no gatekeeping.' },
];
---

<BaseLayout title={title} description={description} canonicalUrl="https://visibility.help/about/" jsonLdScripts={[aboutSchema]} breadcrumbItems={breadcrumbItems}>
  <Header />
  <main>
    <section class="px-4 pt-20 pb-14 md:pt-28 md:pb-20">
      <div class="section-container">
        <div class="max-w-2xl reveal">
          <p class="eyebrow">About</p>
          <h1 class="display-title mt-4 text-4xl font-bold leading-[1.05] sm:text-5xl md:text-6xl">
            Built for the AI Search Era
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-[var(--ink-secondary)]">
            Search is changing. Over 40% of information-seeking sessions now start in AI engines. Traditional SEO doesn't cover this. Visibility does.
          </p>
          <p class="mt-4 text-lg leading-relaxed text-[var(--ink-secondary)]">
            We help brands become the sources that ChatGPT, Perplexity, Gemini, and Claude cite when answering questions. Not through tricks. Through proper infrastructure.
          </p>
        </div>
      </div>
    </section>

    <section class="px-4 pb-14 md:pb-24">
      <div class="section-container">
        <div class="grid gap-4 md:grid-cols-3">
          {values.map((v, i) => (
            <div class={`shell-card p-6 md:p-8 reveal reveal-delay-${i + 1}`}>
              <h3 class="text-lg font-semibold">{v.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-[var(--ink-secondary)]">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="px-4 pb-24 md:pb-32">
      <div class="section-container">
        <div class="shell-card p-8 md:p-16 text-center reveal">
          <h2 class="display-title text-3xl font-bold md:text-4xl">Want to learn more?</h2>
          <p class="mx-auto mt-4 max-w-xl text-[var(--ink-secondary)]">
            We're always happy to talk about AI search visibility and how to build for it.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-4">
            <a href={PRIMARY_CTA.href} class="cta-primary cta-primary--accent">
              {PRIMARY_CTA.label}
              <span class="cta-arrow">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6h8M7 3l3 3-3 3"/></svg>
              </span>
            </a>
            <a href="/contact/" class="cta-secondary">Contact us</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>