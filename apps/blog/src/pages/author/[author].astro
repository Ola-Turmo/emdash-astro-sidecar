---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const authors = await getCollection('authors');
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  
  return authors.map(author => ({
    params: { author: author.id },
    props: {
      author,
      posts: allPosts.filter(post => {
        const postAuthor = post.data.author;
        return typeof postAuthor === 'object' 
          ? (postAuthor as any).id === author.id 
          : postAuthor === author.id;
      }),
    },
  }));
};

const { author, posts } = Astro.props;
const { name, bio, avatar, social } = author.data;
---

<BaseLayout title={name} description={bio}>
  <Header />
  
  <main class="max-w-4xl mx-auto px-4 py-12">
    <!-- Author header -->
    <header class="flex items-start gap-6 mb-12">
      {avatar && (
        <img
          src={avatar.src}
          alt={avatar.alt}
          class="w-20 h-20 rounded-full object-cover"
        />
      )}
      <div>
        <h1 class="text-3xl font-bold text-neutral-900">{name}</h1>
        <p class="text-neutral-600 mt-2">{bio}</p>
        {social && (
          <div class="flex gap-4 mt-4">
            {social.twitter && (
              <a href={social.twitter} class="text-sm text-blue-600 hover:underline" target="_blank" rel="noopener">Twitter</a>
            )}
            {social.github && (
              <a href={social.github} class="text-sm text-neutral-600 hover:underline" target="_blank" rel="noopener">GitHub</a>
            )}
          </div>
        )}
      </div>
    </header>
    
    <!-- Posts -->
    <section>
      <h2 class="text-xl font-bold text-neutral-900 mb-6">Articles</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {posts.map(post => (
          <ArticleCard post={post} />
        ))}
      </div>
      {posts.length === 0 && (
        <p class="text-neutral-500">No articles by this author yet.</p>
      )}
    </section>
  </main>
  
  <Footer />
</BaseLayout>
