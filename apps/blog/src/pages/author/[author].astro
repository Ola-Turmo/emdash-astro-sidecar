---
import type { CollectionEntry } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SHELL_COPY } from '../../consts';
import { getActiveAuthors, getPostAuthorSlug, getPublishedPosts } from '../../lib/published-content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const [authors, allPosts] = await Promise.all([
    getActiveAuthors(),
    getPublishedPosts(),
  ]);

  return authors.map((author: CollectionEntry<'authors'>) => ({
    params: { author: author.slug },
    props: {
      author,
      posts: allPosts.filter((post: CollectionEntry<'blog'>) => {
        const postAuthorSlug = getPostAuthorSlug(post);
        return postAuthorSlug === author.slug || postAuthorSlug === author.id;
      }),
    },
  }));
};

const { author, posts } = Astro.props as { author: CollectionEntry<'authors'>; posts: CollectionEntry<'blog'>[] };
const { name, bio, avatar, social } = author.data;
---

<BaseLayout title={name} description={bio}>
  <Header />

  <main class="mx-auto max-w-6xl px-4 py-12">
    <header class="shell-card mb-12 flex items-start gap-6 p-6 md:p-8">
      {avatar && (
        <img
          src={avatar.src}
          alt={avatar.alt}
          class="h-20 w-20 rounded-full object-cover"
        />
      )}
      <div>
        <p class="eyebrow">{SHELL_COPY.contentMeta.authorEyebrow}</p>
        <h1 class="mt-2 text-3xl font-bold tracking-tight text-[var(--ink)]">{name}</h1>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-[var(--ink-secondary)]">{bio}</p>
        {social && (
          <div class="mt-4 flex gap-4">
            {social.twitter && (
              <a href={social.twitter} class="text-sm font-medium text-[var(--accent)] hover:underline" target="_blank" rel="noopener">Twitter</a>
            )}
            {social.github && (
              <a href={social.github} class="text-sm font-medium text-[var(--ink-secondary)] hover:underline" target="_blank" rel="noopener">GitHub</a>
            )}
          </div>
        )}
      </div>
    </header>

    <section class="reveal">
      <h2 class="display-title text-3xl font-bold text-[var(--ink)]">{SHELL_COPY.contentMeta.articleListingTitle}</h2>
      <div class="mt-6 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {posts.map((post) => (
          <ArticleCard post={post} />
        ))}
      </div>
      {posts.length === 0 && (
        <p class="text-[var(--ink-secondary)]">{SHELL_COPY.contentMeta.authorEmptyText}</p>
      )}
    </section>
  </main>

  <Footer />
</BaseLayout>