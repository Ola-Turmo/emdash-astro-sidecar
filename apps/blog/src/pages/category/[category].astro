---
import CategoryLayout from '../../layouts/CategoryLayout.astro';
import type { CollectionEntry } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import { getActiveCategories, getPostCategorySlug, getPublishedPosts } from '../../lib/published-content';

export const getStaticPaths: GetStaticPaths = async () => {
  const [categories, allPosts] = await Promise.all([
    getActiveCategories(),
    getPublishedPosts(),
  ]);

  return categories.map((category: CollectionEntry<'categories'>) => ({
    params: { category: category.slug },
    props: {
      category,
      posts: allPosts.filter((post: CollectionEntry<'blog'>) => {
        return getPostCategorySlug(post) === category.slug;
      }),
    },
  }));
};

const { category, posts } = Astro.props as { category: CollectionEntry<'categories'>; posts: CollectionEntry<'blog'>[] };
---

<CategoryLayout category={category} posts={posts} />
