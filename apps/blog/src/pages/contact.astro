---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SUPPORT_EMAIL, PRIMARY_CTA, SHELL_COPY } from '../consts';

const title = 'Contact';
const description = 'Get in touch with the Visibility team. Questions about GEO, pricing, or Enterprise plans? We respond within one business day.';

const breadcrumbItems = [
  { name: 'Contact', url: 'https://visibility.help/contact/' },
];

const contactSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Visibility',
  description,
  url: 'https://visibility.help/contact/',
  mainEntity: {
    '@type': 'Organization',
    name: 'Visibility',
    url: 'https://visibility.help',
    email: SUPPORT_EMAIL,
    contactPoint: {
      '@type': 'ContactPoint',
      contactType: 'Customer Support',
      email: SUPPORT_EMAIL,
      availableLanguage: 'English',
    },
  },
});
---

<BaseLayout title={title} description={description} canonicalUrl="https://visibility.help/contact/" jsonLdScripts={[contactSchema]} breadcrumbItems={breadcrumbItems}>
  <Header />
  <main>
    <section class="px-4 pt-20 pb-14 md:pt-28 md:pb-20">
      <div class="section-container">
        <div class="max-w-2xl reveal">
          <p class="eyebrow">Contact</p>
          <h1 class="display-title mt-4 text-4xl font-bold leading-[1.05] sm:text-5xl">
            Let's Talk AI Search
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-[var(--ink-secondary)]">
            Questions about GEO, pricing, or Enterprise? We respond within one business day.
          </p>
        </div>
      </div>
    </section>

    <section class="px-4 pb-24 md:pb-32">
      <div class="section-container">
        <div class="max-w-xl">
          <div class="shell-card p-6 md:p-8 reveal">
            <form action={`mailto:${SUPPORT_EMAIL}`} method="post" enctype="text/plain" class="space-y-5">
              <div>
                <label for="name" class="block text-sm font-medium mb-1.5">Name</label>
                <input type="text" id="name" name="name" required placeholder="Your name" class="block w-full rounded-xl border border-[var(--border-strong)] bg-var(--surface)] px-4 py-2.5 text-sm text-[var(--ink)] placeholder-[var(--ink-muted)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium mb-1.5">Work Email</label>
                <input type="email" id="email" name="email" required placeholder="you@company.com" class="block w-full rounded-xl border border-[var(--border-strong)] bg-white px-4 py-2.5 text-sm text-[var(--ink)] placeholder-[var(--ink-muted)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors" />
              </div>
              <div>
                <label for="company" class="block text-sm font-medium mb-1.5">Company</label>
                <input type="text" id="company" name="company" placeholder="Acme Inc" class="block w-full rounded-xl border border-[var(--border-strong)] bg-white px-4 py-2.5 text-sm text-[var(--ink)] placeholder-[var(--ink-muted)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors" />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium mb-1.5">Message</label>
                <textarea id="message" name="message" required placeholder="Tell us about your project..." rows="4" class="block w-full rounded-xl border border-[var(--border-strong)] bg-white px-4 py-2.5 text-sm text-[var(--ink)] placeholder-[var(--ink-muted)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors resize-none"></textarea>
              </div>
              <button type="submit" class="cta-primary cta-primary--accent w-full justify-center">
                Send Message
                <span class="cta-arrow">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6h8M7 3l3 3-3 3"/></svg>
                </span>
              </button>
            </form>
          </div>

          <div class="mt-8 grid grid-cols-2 gap-4 reveal reveal-delay-1">
            <div class="shell-card p-5">
              <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-[var(--ink-muted)]">Response time</p>
              <p class="mt-2 text-sm font-medium">Within 1 business day</p>
            </div>
            <div class="shell-card p-5">
              <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-[var(--ink-muted)]">Email</p>
              <p class="mt-2 text-sm font-medium">{SUPPORT_EMAIL}</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>