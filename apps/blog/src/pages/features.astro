---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { PRIMARY_CTA, SECONDARY_CTA, SHELL_COPY } from '../consts';

const title = 'Features';
const description = 'AI-powered GEO tools that structure your content for citation by ChatGPT, Perplexity, Gemini, and Claude. From llms.txt to structured data to citability scoring.';

const breadcrumbItems = [
  { name: 'Features', url: 'https://visibility.help/features/' },
];

const featureListSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Visibility Platform Features',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'llms.txt Generation', description: 'Auto-generate and maintain an llms.txt file that tells AI systems exactly what your business does.' },
    { '@type': 'ListItem', position: 2, name: 'Structured Data Automation', description: 'JSON-LD schemas for Organization, WebSite, SoftwareApplication, BlogPosting, FAQPage, and BreadcrumbList.' },
    { '@type': 'ListItem', position: 3, name: 'AI Crawler Optimization', description: 'Robots.txt configured to allow GPTBot, ClaudeBot, PerplexityBot while blocking bad actors.' },
    { '@type': 'ListItem', position: 4, name: 'Content Citability Scoring', description: 'Real-time analysis of fact-block density, information gain, and passage-level answer readiness.' },
    { '@type': 'ListItem', position: 5, name: 'Semantic HTML Audits', description: 'Automated checks for proper landmarks, heading hierarchy, ARIA labels, and schema markup.' },
    { '@type': 'ListItem', position: 6, name: 'AI Citation Reports', description: 'Weekly reports on which AI engines cite your content, with optimization suggestions.' },
  ],
});

const features = [
  {
    category: 'Visibility Infrastructure',
    items: [
      { title: 'llms.txt Generator', desc: 'Auto-generate and maintain an llms.txt file that tells AI systems exactly what your business does, who it serves, and why it matters.', icon: 'doc' },
      { title: 'Structured Data Automation', desc: 'JSON-LD schemas for Organization, WebSite, SoftwareApplication, BlogPosting, FAQPage, and BreadcrumbList injected on every page.', icon: 'code' },
      { title: 'AI Crawler Access', desc: 'Robots.txt rules configured to allow GPTBot, CCBot, ClaudeBot, PerplexityBot, and OAI-SearchBot while blocking scrapers that don\'t attribute.', icon: 'shield' },
    ],
  },
  {
    category: 'Content Intelligence',
    items: [
      { title: 'Content Citability Scoring', desc: 'Real-time analysis of your content for fact-block density, unique information gain, and passage-level answer readiness.', icon: 'chart' },
      { title: 'Semantic HTML Audits', desc: 'Automated checks for proper landmarks, heading hierarchy, ARIA labels, and schema markup that AI parsers rely on.', icon: 'scan' },
      { title: 'Citation Reports', desc: 'Weekly reports on which AI engines cite your content, with specific optimization suggestions for each.', icon: 'report' },
    ],
  },
];

const iconMap: Record<string, string> = {
  doc: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8M16 17H8M10 9H8"/></svg>',
  code: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
  shield: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
  chart: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>',
  scan: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V5a2 2 0 012-2h2M17 3h2a2 2 0 012 2v2M21 17v2a2 2 0 01-2 2h-2M7 21H5a2 2 0 01-2-2v-2"/><path d="M7 12h10"/></svg>',
  report: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/><path d="M12 18v-6M9 15h6"/></svg>',
};
---

<BaseLayout title={title} description={description} canonicalUrl="https://visibility.help/features/" jsonLdScripts={[featureListSchema]} breadcrumbItems={breadcrumbItems}>
  <Header />
  <main>
    <!-- Hero -->
    <section class="px-4 pt-20 pb-16 md:pt-28 md:pb-24">
      <div class="section-container">
        <div class="max-w-2xl reveal">
          <p class="eyebrow">Features</p>
          <h1 class="display-title mt-4 text-4xl font-bold leading-[1.05] sm:text-5xl md:text-6xl">
            Built for the AI Search Era
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-[var(--ink-secondary)]">
            Every feature is designed to make your brand discoverable and citable by AI language models. No SEO theater. Just the infrastructure that matters.
          </p>
        </div>
      </div>
    </section>

    {/* Feature Groups */}
    {features.map((group, gi) => (
      <section class="px-4 pb-16 md:pb-24">
        <div class="section-container">
          <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-[var(--ink-muted)] mb-6 reveal">{group.category}</p>
          <div class="grid gap-4 md:grid-cols-3">
            {group.items.map((feature, fi) => (
              <div class={`shell-card p-6 md:p-8 reveal reveal-delay-${fi + 1}`}>
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[var(--accent-light)] text-[var(--accent)]" set:html={iconMap[feature.icon]} />
                <h3 class="mt-5 text-lg font-semibold">{feature.title}</h3>
                <p class="mt-3 text-sm leading-relaxed text-[var(--ink-secondary)]">{feature.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    ))}

    {/* CTA */}
    <section class="px-4 pb-24 md:pb-32">
      <div class="section-container">
        <div class="shell-card p-8 md:p-16 text-center reveal">
          <h2 class="display-title text-3xl font-bold md:text-4xl">Start Getting Cited by AI</h2>
          <p class="mx-auto mt-4 max-w-xl text-[var(--ink-secondary)]">
            Deploy the full Visibility stack in minutes. Free to start, no credit card required.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-4">
            <a href={PRIMARY_CTA.href} class="cta-primary cta-primary--accent">
              {PRIMARY_CTA.label}
              <span class="cta-arrow">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6h8M7 3l3 3-3 3"/></svg>
              </span>
            </a>
            <a href="/contact/" class="cta-secondary">Talk to us</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>