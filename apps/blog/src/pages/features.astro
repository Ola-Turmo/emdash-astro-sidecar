---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_NAME, SITE_DESCRIPTION, PRIMARY_CTA, SECONDARY_CTA, SHELL_COPY } from '../consts';

const title = 'Features';
const description = 'AI-powered GEO tools that structure your content for citation by ChatGPT, Perplexity, Gemini, and Claude. From llms.txt to structured data, Visibility handles the technical work.';

const breadcrumbItems = [
  { name: 'Features', url: 'https://visibility.help/features/' },
];

const featureListSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Visibility Platform Features',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'llms.txt Generation', description: 'Auto-generate and maintain an llms.txt file that tells AI systems exactly what your business does, who it serves, and why it matters.' },
    { '@type': 'ListItem', position: 2, name: 'Structured Data Automation', description: 'JSON-LD schemas for Organization, WebSite, SoftwareApplication, BlogPosting, FAQPage, and BreadcrumbList injected on every page.' },
    { '@type': 'ListItem', position: 3, name: 'AI Crawler Optimization', description: 'Robots.txt configured to allow GPTBot, CCBot, ClaudeBot, Google-Extended, and other AI crawlers while blocking bad actors.' },
    { '@type': 'ListItem', position: 4, name: 'Content Citability Scoring', description: 'Real-time analysis of your content for fact-block density, unique information gain, and passage-level answer readiness.' },
    { '@type': 'ListItem', position: 5, name: 'Semantic HTML Audits', description: 'Automated checks for proper landmarks, heading hierarchy, ARIA labels, and schema markup that AI parsers rely on.' },
    { '@type': 'ListItem', position: 6, name: 'Edge Performance', description: 'Built on Cloudflare for sub-100ms TTFB globally. Static generation, Brotli compression, and aggressive asset caching.' },
  ],
});

const features = [
  {
    title: 'llms.txt Generation',
    description: 'Auto-generate and maintain an llms.txt file that tells AI systems exactly what your business does, who it serves, and why it matters.',
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
  {
    title: 'Structured Data Automation',
    description: 'JSON-LD schemas for Organization, WebSite, SoftwareApplication, BlogPosting, FAQPage, and BreadcrumbList injected on every page.',
    icon: 'M4 6h16M4 12h16M4 18h16',
  },
  {
    title: 'AI Crawler Optimization',
    description: 'Robots.txt configured to allow GPTBot, CCBot, ClaudeBot, Google-Extended, and other AI crawlers while blocking bad actors.',
    icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
  },
  {
    title: 'Content Citability Scoring',
    description: 'Real-time analysis of your content for fact-block density, unique information gain, and passage-level answer readiness.',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  },
  {
    title: 'Semantic HTML Audits',
    description: 'Automated checks for proper landmarks, heading hierarchy, ARIA labels, and schema markup that AI parsers rely on.',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  },
  {
    title: 'Edge Performance',
    description: 'Built on Cloudflare for sub-100ms TTFB globally. Static generation, Brotli compression, and aggressive asset caching.',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
];
---

<BaseLayout title={title} description={description} canonicalUrl="https://visibility.help/features/" jsonLdScripts={[featureListSchema]} breadcrumbItems={breadcrumbItems}>
  <Header />
  <main>
    <section class="px-3 pb-14 pt-10 sm:px-4 md:pb-24 md:pt-20">
      <div class="mx-auto max-w-6xl">
        <p class="eyebrow">Platform Capabilities</p>
        <h1 class="display-title mt-4 max-w-4xl text-4xl font-black leading-[1.03] text-slate-950 sm:text-5xl md:text-6xl">
          Everything You Need for AI Search Visibility
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-7 text-slate-600 sm:text-lg sm:leading-8">
          Visibility automates the technical infrastructure of Generative Engine Optimization so your brand gets cited by AI search engines.
        </p>
      </div>
    </section>

    <section class="px-3 pb-14 sm:px-4 md:pb-24">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {features.map((feature) => (
            <div class="shell-card p-6 sm:p-8">
              <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-teal-600/10 text-teal-700">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
                </svg>
              </div>
              <h2 class="mt-5 text-lg font-extrabold tracking-tight text-slate-900">{feature.title}</h2>
              <p class="mt-2 text-sm leading-6 text-slate-600">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="px-3 pb-14 sm:px-4 md:pb-24">
      <div class="mx-auto max-w-6xl">
        <div class="shell-card overflow-hidden">
          <div class="grid lg:grid-cols-2">
            <div class="p-6 sm:p-10">
              <p class="eyebrow">How It Works</p>
              <h2 class="display-title mt-4 text-3xl font-bold text-slate-950 md:text-4xl">
                From Invisible to Cited in Three Steps
              </h2>
              <div class="mt-8 space-y-6">
                <div class="flex gap-4">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-teal-600 text-sm font-bold text-white">1</div>
                  <div>
                    <p class="font-bold text-slate-900">Audit Your AI Visibility</p>
                    <p class="mt-1 text-sm leading-6 text-slate-600">We scan your site for GEO readiness: structured data, llms.txt, crawler access, and content citability.</p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-teal-600 text-sm font-bold text-white">2</div>
                  <div>
                    <p class="font-bold text-slate-900">Deploy Optimized Content</p>
                    <p class="mt-1 text-sm leading-6 text-slate-600">Our platform generates GEO-optimized pages with fact blocks, schema markup, and AI-readable structure.</p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-teal-600 text-sm font-bold text-white">3</div>
                  <div>
                    <p class="font-bold text-slate-900">Measure Citations</p>
                    <p class="mt-1 text-sm leading-6 text-slate-600">Track when and where AI engines cite your brand. Monitor share of voice across ChatGPT, Perplexity, Gemini, and Claude.</p>
                  </div>
                </div>
              </div>
              <div class="mt-8 flex flex-wrap gap-3">
                <a href={PRIMARY_CTA.href} class="cta-primary">{PRIMARY_CTA.label}</a>
                <a href={SECONDARY_CTA.href} class="cta-secondary">{SECONDARY_CTA.label}</a>
              </div>
            </div>
            <div class="relative hidden bg-slate-950 lg:block">
              <div class="absolute inset-0 bg-gradient-to-br from-teal-600/20 via-slate-900 to-amber-500/10"></div>
              <div class="relative flex h-full items-center justify-center p-10">
                <div class="w-full max-w-md space-y-4">
                  <div class="rounded-xl border border-slate-700/50 bg-slate-900/80 p-4 backdrop-blur">
                    <p class="text-xs font-bold uppercase tracking-wider text-emerald-400">llms.txt</p>
                    <p class="mt-2 font-mono text-xs text-slate-300"># Visibility — AI Search Visibility Platform</p>
                    <p class="font-mono text-xs text-slate-400">&gt; For: Marketing teams, SEO agencies, SaaS founders</p>
                    <p class="font-mono text-xs text-slate-400">&gt; What: GEO optimization and AI citation tooling</p>
                  </div>
                  <div class="rounded-xl border border-slate-700/50 bg-slate-900/80 p-4 backdrop-blur">
                    <p class="text-xs font-bold uppercase tracking-wider text-emerald-400">Schema.org</p>
                    <p class="font-mono text-xs text-slate-300">{'{ "@type": "SoftwareApplication", ... }'}</p>
                  </div>
                  <div class="rounded-xl border border-slate-700/50 bg-slate-900/80 p-4 backdrop-blur">
                    <p class="text-xs font-bold uppercase tracking-wider text-emerald-400">Citability Score</p>
                    <p class="font-mono text-xs text-slate-300">94/100 — High citation probability</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
