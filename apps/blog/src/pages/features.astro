---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { PRIMARY_CTA, SECONDARY_CTA, SHELL_COPY } from '../consts';

const title = 'Features';
const description = 'Emdash generates, optimizes, and publishes AI-powered content to your website. From article generation to GEO optimization to one-click publishing.';

const breadcrumbItems = [
  { name: 'Features', url: 'https://visibility.help/features/' },
];

const featureListSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Emdash Platform Features',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AI Article Generation', description: 'Generate full SEO-ready articles from a topic or keyword. AI researches, writes, and structures the content.' },
    { '@type': 'ListItem', position: 2, name: 'GEO Optimization', description: 'Structure every article so AI search engines like ChatGPT and Perplexity can cite and recommend it.' },
    { '@type': 'ListItem', position: 3, name: 'One-Click Publishing', description: 'Review generated content in your dashboard, click approve, and it goes live on your site instantly.' },
    { '@type': 'ListItem', position: 4, name: 'Structured Data Automation', description: 'JSON-LD schemas for Organization, WebSite, BlogPosting, FAQPage, and BreadcrumbList injected automatically.' },
    { '@type': 'ListItem', position: 5, name: 'Multi-Site Management', description: 'Run one Emdash instance and publish content to multiple websites from a single dashboard.' },
    { '@type': 'ListItem', position: 6, name: 'SEO Score Tracking', description: 'Real-time SEO and citability scoring for every article before you hit publish.' },
  ],
});

const features = [
  {
    category: 'Content Generation',
    items: [
      { title: 'AI Article Writer', desc: 'Enter a topic or keyword. Emdash researches, outlines, and writes a full article with headings, citations, and calls to action.', icon: 'pen' },
      { title: 'Brand Voice Training', desc: 'Feed Emdash your existing content and it learns your tone. Every article sounds like you wrote it.', icon: 'voice' },
      { title: 'Bulk Generation', desc: 'Queue up 10, 20, or 50 articles at once. Emdash works through them while you focus on other things.', icon: 'stack' },
    ],
  },
  {
    category: 'Optimization & Publishing',
    items: [
      { title: 'GEO-Ready Structure', desc: 'Every article is structured with fact blocks, clear headings, and dense information so AI engines cite it naturally.', icon: 'geo' },
      { title: 'Auto Structured Data', desc: 'JSON-LD schemas for Organization, WebSite, BlogPosting, FAQPage, and BreadcrumbList injected on every page.', icon: 'code' },
      { title: 'One-Click Publish', desc: 'Review the generated article in your dashboard. Click approve and it goes live on your site in seconds.', icon: 'rocket' },
    ],
  },
];

const iconMap: Record<string, string> = {
  pen: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
  voice: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2M12 19v4M8 23h8"/></svg>',
  stack: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>',
  geo: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>',
  code: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
  rocket: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 00-2.91-.09zM12 15l-3-3a22 22 0 012-3.95A12.88 12.88 0 0122 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 01-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>',
};
---

<BaseLayout title={title} description={description} canonicalUrl="https://visibility.help/features/" jsonLdScripts={[featureListSchema]} breadcrumbItems={breadcrumbItems}>
  <Header />
  <main>
    <!-- Hero -->
    <section class="px-4 pt-20 pb-16 md:pt-28 md:pb-24">
      <div class="section-container">
        <div class="max-w-2xl reveal">
          <p class="eyebrow">Features</p>
          <h1 class="display-title mt-4 text-4xl font-bold leading-[1.05] sm:text-5xl md:text-6xl">
            Everything You Need to Publish at Scale
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-[var(--ink-secondary)]">
            Emdash handles the entire content pipeline: research, writing, optimization, and publishing. You just review and approve.
          </p>
        </div>
      </div>
    </section>

    {/* Feature Groups */}
    {features.map((group, gi) => (
      <section class="px-4 pb-16 md:pb-24">
        <div class="section-container">
          <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-[var(--ink-muted)] mb-6 reveal">{group.category}</p>
          <div class="grid gap-4 md:grid-cols-3">
            {group.items.map((feature, fi) => (
              <div class={`shell-card p-6 md:p-8 reveal reveal-delay-${fi + 1}`}>
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[var(--accent-light)] text-[var(--accent)]" set:html={iconMap[feature.icon]} />
                <h3 class="mt-5 text-lg font-semibold">{feature.title}</h3>
                <p class="mt-3 text-sm leading-relaxed text-[var(--ink-secondary)]">{feature.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    ))}

    {/* How it Works */}
    <section class="px-4 pb-16 md:pb-24">
      <div class="section-container">
        <div class="max-w-2xl reveal">
          <p class="eyebrow">How It Works</p>
          <h2 class="display-title mt-4 text-3xl font-bold md:text-4xl">From Idea to Published in 4 Steps</h2>
        </div>
        <div class="mt-10 grid gap-4 md:grid-cols-4">
          {[
            { step: '1', title: 'Enter a Topic', desc: 'Type a keyword or topic. Emdash researches what ranks and what AI engines are citing.' },
            { step: '2', title: 'AI Writes It', desc: 'Emdash generates a full article with SEO structure, fact blocks, and calls to action.' },
            { step: '3', title: 'You Review', desc: 'Check the article in your dashboard. Edit anything. The SEO score updates in real time.' },
            { step: '4', title: 'Click Publish', desc: 'Approve and the article goes live on your site, with structured data and GEO optimization.' },
          ].map((s, i) => (
            <div class={`shell-card p-6 reveal reveal-delay-${i + 1}`}>
              <p class="text-3xl font-bold text-[var(--accent)]">{s.step}</p>
              <h3 class="mt-3 text-base font-semibold">{s.title}</h3>
              <p class="mt-2 text-sm text-[var(--ink-secondary)]">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="px-4 pb-24 md:pb-32">
      <div class="section-container">
        <div class="shell-card p-8 md:p-16 text-center reveal">
          <h2 class="display-title text-3xl font-bold md:text-4xl">Start Publishing Today</h2>
          <p class="mx-auto mt-4 max-w-xl text-[var(--ink-secondary)]">
            Free to start. No credit card required. Your first article can be live in under 30 minutes.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-4">
            <a href={PRIMARY_CTA.href} class="cta-primary cta-primary--accent">
              {PRIMARY_CTA.label}
              <span class="cta-arrow">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6h8M7 3l3 3-3 3"/></svg>
              </span>
            </a>
            <a href="/setup/" class="cta-secondary">See setup guide</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
