---
import type { CollectionEntry } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import DirectorySearch from '../components/DirectorySearch.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MunicipalityCard from '../components/MunicipalityCard.astro';
import { deriveMunicipalityView } from '../lib/municipality-view';
import { getPublishedMunicipalPages, getPublishedPosts } from '../lib/published-content';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  ACTIVE_CONCEPT_KEY,
  CONCEPT_PAGE_STRUCTURE,
  COURSE_LINKS,
  PRIMARY_CTA,
  SECONDARY_CTA,
  SHELL_COPY,
  SITE_DESCRIPTION,
  SITE_NAME,
  articlePath,
} from '../consts';

const isMunicipalityConcept = ACTIVE_CONCEPT_KEY === 'kommune' && CONCEPT_PAGE_STRUCTURE === 'directory';
const allPosts = isMunicipalityConcept ? [] : await getPublishedPosts();
const sortedPosts = allPosts.sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featuredPosts = sortedPosts.slice(0, 6);
const municipalityPages = isMunicipalityConcept ? await getPublishedMunicipalPages() : [];
const sortedMunicipalities = municipalityPages.sort((a, b) =>
  a.data.municipality.localeCompare(b.data.municipality, 'nb'),
);
const featuredMunicipalities = sortedMunicipalities.slice(0, 12);
const municipalitySearchOptions = sortedMunicipalities.map((page) => ({
  label: page.data.municipality,
  href: articlePath(page.slug),
  meta: page.data.county,
}));
const landingTitle = isMunicipalityConcept ? SHELL_COPY.homeTitle : SITE_NAME;
---

<BaseLayout title={landingTitle} description={SITE_DESCRIPTION}>
  <Header />

  <main class="pt-[5.5rem] lg:pt-0">
    <!-- Hero Section -->
    <section class="px-4 pt-12 pb-16 md:pt-28 md:pb-24">
      <div class="mx-auto max-w-6xl hero-grid">
        <div class="reveal">
          <p class="eyebrow">{SHELL_COPY.homeEyebrow}</p>
          <h1 class="display-title mt-5 max-w-3xl text-4xl font-bold leading-[1.05] tracking-tight text-[var(--color-ink)] md:text-[3.5rem] lg:text-[4rem]">
            {SHELL_COPY.homeTitle}
          </h1>
          <p class="mt-6 max-w-xl text-[1.0625rem] leading-7 text-[var(--color-muted)] md:text-lg md:leading-8">
            {SHELL_COPY.homeDescription}
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={PRIMARY_CTA.href} class="cta-primary">{PRIMARY_CTA.label}</a>
            <a href={SECONDARY_CTA.href} class="cta-secondary">{SECONDARY_CTA.label}</a>
          </div>
          {SHELL_COPY.homeStats.length > 0 && (
            <div class="mt-12 grid gap-6 sm:grid-cols-3 reveal-delay-2">
              {SHELL_COPY.homeStats.map((stat: (typeof SHELL_COPY.homeStats)[number]) => (
                <div>
                  <p class="font-mono text-3xl font-bold tracking-tight text-[var(--color-ink)]">{stat.value}</p>
                  <p class="mt-1 text-sm leading-6 text-[var(--color-muted)]">{stat.label}</p>
                </div>
              ))}
            </div>
          )}
        </div>

        <aside class="reveal reveal-delay-2">
          <div class="shell-card p-6 md:p-8">
            <p class="eyebrow">{SHELL_COPY.homeAsideEyebrow}</p>
            {isMunicipalityConcept ? (
              <div class="mt-6 space-y-3">
                {featuredMunicipalities.slice(0, 3).map((page) => (
                  <a
                    href={articlePath(page.slug)}
                    class="block rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-4 transition-all duration-200 hover:border-[var(--color-ink)]/20 hover:shadow-[0_2px_8px_rgba(0,0,0,0.04)]"
                  >
                    <p class="text-[0.9375rem] font-semibold tracking-tight text-[var(--color-ink)]">{page.data.municipality}</p>
                    <p class="mt-1 text-sm leading-6 text-[var(--color-muted)]">{deriveMunicipalityView(page.data).cardSummary}</p>
                  </a>
                ))}
              </div>
            ) : (
              <div class="mt-6 space-y-3">
                {COURSE_LINKS.map((link: (typeof COURSE_LINKS)[number]) => (
                  <a
                    href={link.href}
                    class="block rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-4 transition-all duration-200 hover:border-[var(--color-ink)]/20 hover:shadow-[0_2px_8px_rgba(0,0,0,0.04)]"
                  >
                    <p class="text-[0.9375rem] font-semibold tracking-tight text-[var(--color-ink)]">{link.label}</p>
                    <p class="mt-1 text-sm leading-6 text-[var(--color-muted)]">{link.description}</p>
                  </a>
                ))}
              </div>
            )}
            <div class="mt-6 rounded-lg bg-[var(--color-ink)] p-5 text-white">
              <p class="text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-[var(--color-highlight)]">
                {SHELL_COPY.homeAsideReasonTitle}
              </p>
              <p class="mt-3 text-sm leading-7 text-[#B8B5AF]">{SHELL_COPY.homeAsideReasonText}</p>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <!-- Content Listing Section -->
    <section class="px-4 pb-16 md:pb-24">
      <div class="mx-auto max-w-6xl">
        {isMunicipalityConcept && municipalitySearchOptions.length > 0 && (
          <DirectorySearch
            options={municipalitySearchOptions}
            eyebrow={SHELL_COPY.directorySearchEyebrow}
            title={SHELL_COPY.directorySearchTitle}
            description={SHELL_COPY.directorySearchDescription}
            placeholder={SHELL_COPY.directorySearchPlaceholder}
            emptyText={SHELL_COPY.directorySearchEmpty}
            ariaLabel={SHELL_COPY.directorySearchAriaLabel}
            actionLabel={SHELL_COPY.directorySearchActionLabel}
            metaFallback={SHELL_COPY.directorySearchMetaFallback}
          />
        )}

        <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between reveal">
          <div>
            <p class="eyebrow">{SHELL_COPY.listingEyebrow}</p>
            <h2 class="display-title mt-2 text-2xl font-semibold text-[var(--color-ink)] md:text-3xl">
              {SHELL_COPY.listingTitle}
            </h2>
          </div>
          <p class="max-w-xl text-sm leading-7 text-[var(--color-muted)]">{SHELL_COPY.listingDescription}</p>
        </div>

        {isMunicipalityConcept ? (
          <>
            <div class="editorial-grid mt-8">
              {featuredMunicipalities.map((page) => (
                <MunicipalityCard page={page} />
              ))}
            </div>
            {featuredMunicipalities.length === 0 && (
              <p class="py-16 text-center text-[var(--color-muted)]">{SHELL_COPY.listingEmptyText}</p>
            )}
          </>
        ) : (
          <>
            <div class="editorial-grid mt-8">
              {featuredPosts.map((post: CollectionEntry<'blog'>) => (
                <ArticleCard post={post} />
              ))}
            </div>

            {featuredPosts.length === 0 && (
              <p class="py-16 text-center text-[var(--color-muted)]">{SHELL_COPY.listingEmptyText}</p>
            )}
          </>
        )}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>