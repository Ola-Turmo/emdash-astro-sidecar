---
import type { CollectionEntry } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getPublishedPosts } from '../lib/published-content';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  PRIMARY_CTA,
  SECONDARY_CTA,
  SHELL_COPY,
  SITE_DESCRIPTION,
  SITE_NAME,
  blogPath,
} from '../consts';

const allPosts = await getPublishedPosts();
const sortedPosts = allPosts.sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featuredPosts = sortedPosts.slice(0, 6);
---

<BaseLayout title={SITE_NAME} description={SITE_DESCRIPTION}>
  <Header />

  <main>
    <!-- Hero -->
    <section class="px-4 pt-20 pb-24 md:pt-32 md:pb-32 lg:pt-40 lg:pb-40">
      <div class="section-container">
        <div class="max-w-3xl">
          <p class="eyebrow reveal">{SHELL_COPY.homeEyebrow}</p>
          <h1 class="display-title mt-5 text-4xl font-bold leading-[1.05] sm:text-5xl md:text-6xl lg:text-7xl reveal reveal-delay-1">
            {SHELL_COPY.homeTitle}
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-[var(--ink-secondary)] md:text-xl reveal reveal-delay-2">
            {SHELL_COPY.homeDescription}
          </p>
          <div class="mt-10 flex flex-wrap gap-4 reveal reveal-delay-3">
            <a href={PRIMARY_CTA.href} class="cta-primary cta-primary--accent">
              {PRIMARY_CTA.label}
              <span class="cta-arrow">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6h8M7 3l3 3-3 3"/></svg>
              </span>
            </a>
            <a href={SECONDARY_CTA.href} class="cta-secondary">
              {SECONDARY_CTA.label}
            </a>
          </div>
          {SHELL_COPY.homeStats.length > 0 && (
            <div class="mt-14 grid grid-cols-3 gap-6 reveal reveal-delay-4">
              {SHELL_COPY.homeStats.map((stat: (typeof SHELL_COPY.homeStats)[number]) => (
                <div>
                  <p class="text-2xl font-bold tracking-tight md:text-3xl">{stat.value}</p>
                  <p class="mt-1 text-sm text-[var(--ink-muted)]">{stat.label}</p>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Features Mini Bento -->
    <section class="px-4 pb-24 md:pb-32">
      <div class="section-container">
        <div class="grid gap-4 md:grid-cols-3 lg:grid-cols-3">
          {[
            { icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>`, title: 'Structured Data', desc: 'JSON-LD schemas injected automatically for Organization, WebSite, SoftwareApplication, and every page type.' },
            { icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`, title: 'AI Crawler Access', desc: 'Robots.txt rules allowing GPTBot, ClaudeBot, PerplexityBot while blocking scrapers that don\'t attribute.' },
            { icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 016.5 2H20v20H6.5A2.5 2.5 0 014 17.5z"/><path d="M10 9h4M10 13h2"/></svg>`, title: 'Content Citability', desc: 'Score your content for fact-block density, information gain, and passage-level answer readiness.' },
          ].map((feature, i) => (
            <div class={`shell-card p-6 md:p-8 reveal reveal-delay-${i + 1}`}>
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[var(--accent-light)] text-[var(--accent)]" set:html={feature.icon} />
              <h3 class="mt-4 text-base font-semibold">{feature.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-[var(--ink-secondary)]">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Blog / Resources -->
    {featuredPosts.length > 0 && (
      <section class="px-4 pb-24 md:pb-32">
        <div class="section-container">
          <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between reveal">
            <div>
              <p class="eyebrow">{SHELL_COPY.listingEyebrow}</p>
              <h2 class="display-title mt-2 text-2xl font-bold md:text-3xl">{SHELL_COPY.listingTitle}</h2>
            </div>
            <a href={blogPath('/blog/')} class="text-sm font-medium text-[var(--accent-hover)] transition-colors hover:text-[var(--accent)]">
              View all &rarr;
            </a>
          </div>

          <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {featuredPosts.map((post: CollectionEntry<'blog'>, i: number) => (
              <div class={`reveal reveal-delay-${Math.min(i + 1, 3)}`}>
                <ArticleCard post={post} />
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* CTA Section */}
    <section class="px-4 pb-24 md:pb-32">
      <div class="section-container">
        <div class="shell-card p-8 md:p-16 text-center reveal">
          <p class="eyebrow">{SHELL_COPY.footerEyebrow}</p>
          <h2 class="display-title mt-4 text-3xl font-bold md:text-4xl">{SHELL_COPY.footerTitle}</h2>
          <p class="mx-auto mt-4 max-w-xl text-[var(--ink-secondary)]">{SHELL_COPY.footerDescription}</p>
          <div class="mt-8 flex flex-wrap justify-center gap-4">
            <a href={PRIMARY_CTA.href} class="cta-primary cta-primary--accent">
              {PRIMARY_CTA.label}
              <span class="cta-arrow">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6h8M7 3l3 3-3 3"/></svg>
              </span>
            </a>
            <a href="/contact/" class="cta-secondary">
              {SHELL_COPY.footerContactLabel}
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>