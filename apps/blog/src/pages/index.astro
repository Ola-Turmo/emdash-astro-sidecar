---
import type { CollectionEntry } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import DirectorySearch from '../components/DirectorySearch.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MunicipalityCard from '../components/MunicipalityCard.astro';
import { deriveMunicipalityView } from '../lib/municipality-view';
import { getPublishedMunicipalPages, getPublishedPosts } from '../lib/published-content';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  ACTIVE_CONCEPT_KEY,
  CONCEPT_PAGE_STRUCTURE,
  COURSE_LINKS,
  PRIMARY_CTA,
  SECONDARY_CTA,
  SHELL_COPY,
  SITE_DESCRIPTION,
  SITE_NAME,
  articlePath,
} from '../consts';

const isMunicipalityConcept = ACTIVE_CONCEPT_KEY === 'kommune' && CONCEPT_PAGE_STRUCTURE === 'directory';
const allPosts = isMunicipalityConcept ? [] : await getPublishedPosts();
const sortedPosts = allPosts.sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featuredPosts = sortedPosts.slice(0, 6);
const municipalityPages = isMunicipalityConcept ? await getPublishedMunicipalPages() : [];
const sortedMunicipalities = municipalityPages.sort((a, b) =>
  a.data.municipality.localeCompare(b.data.municipality, 'nb'),
);
const featuredMunicipalities = sortedMunicipalities.slice(0, 12);
const municipalitySearchOptions = sortedMunicipalities.map((page) => ({
  label: page.data.municipality,
  href: articlePath(page.slug),
  meta: page.data.county,
}));
const landingTitle = isMunicipalityConcept ? SHELL_COPY.homeTitle : SITE_NAME;
---

<BaseLayout title={landingTitle} description={SITE_DESCRIPTION}>
  <Header />

  <main>
    <section class="overflow-hidden px-3 pb-14 pt-10 sm:px-4 md:pb-24 md:pt-20">
      <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[1.15fr,0.85fr] lg:items-center">
        <div>
          <p class="eyebrow">{SHELL_COPY.homeEyebrow}</p>
          <h1 class="display-title mt-4 max-w-4xl text-4xl font-black leading-[1.03] text-slate-950 sm:text-5xl md:text-7xl">
            {SHELL_COPY.homeTitle}
          </h1>
          <p class="mt-5 max-w-2xl text-base leading-7 text-slate-600 sm:text-lg sm:leading-8">
            {SHELL_COPY.homeDescription}
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={PRIMARY_CTA.href} class="cta-primary">
              {PRIMARY_CTA.label}
            </a>
            <a href={SECONDARY_CTA.href} class="cta-secondary">
              {SECONDARY_CTA.label}
            </a>
          </div>
          {SHELL_COPY.homeStats.length > 0 && (
            <div class="mt-10 grid gap-4 sm:grid-cols-3">
              {SHELL_COPY.homeStats.map((stat: (typeof SHELL_COPY.homeStats)[number]) => (
                <div class="shell-card p-4 sm:p-5">
                  <p class="text-3xl font-black text-slate-900">{stat.value}</p>
                  <p class="mt-2 text-sm leading-6 text-slate-600">{stat.label}</p>
                </div>
              ))}
            </div>
          )}
        </div>

        <aside class="shell-card relative overflow-hidden p-5 md:p-8">
          <div class="absolute inset-x-0 top-0 h-24 bg-gradient-to-r from-teal-600/12 via-slate-900/8 to-amber-500/12"></div>
          <div class="relative">
            <p class="eyebrow">{SHELL_COPY.homeAsideEyebrow}</p>
            {isMunicipalityConcept ? (
              <div class="mt-6 space-y-5">
                {featuredMunicipalities.slice(0, 3).map((page) => (
                  <a
                    href={articlePath(page.slug)}
                    class="block rounded-[1.35rem] border border-slate-200/80 bg-white/90 p-4 transition-transform hover:-translate-y-0.5 sm:p-5"
                  >
                    <p class="text-lg font-extrabold tracking-tight text-slate-900">{page.data.municipality}</p>
                    <p class="mt-2 text-sm leading-6 text-slate-600">{deriveMunicipalityView(page.data).cardSummary}</p>
                  </a>
                ))}
              </div>
            ) : (
              <div class="mt-6 space-y-5">
                {COURSE_LINKS.map((link: (typeof COURSE_LINKS)[number]) => (
                  <a
                    href={link.href}
                    class="block rounded-[1.35rem] border border-slate-200/80 bg-white/90 p-4 transition-transform hover:-translate-y-0.5 sm:p-5"
                  >
                    <p class="text-lg font-extrabold tracking-tight text-slate-900">{link.label}</p>
                    <p class="mt-2 text-sm leading-6 text-slate-600">{link.description}</p>
                  </a>
                ))}
              </div>
            )}
            <div class="mt-6 rounded-[1.35rem] bg-slate-950 p-4 text-white sm:p-5">
              <p class="text-sm font-bold uppercase tracking-[0.18em] text-emerald-300">
                {SHELL_COPY.homeAsideReasonTitle}
              </p>
              <p class="mt-3 text-sm leading-7 text-slate-300">{SHELL_COPY.homeAsideReasonText}</p>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="px-3 pb-14 sm:px-4 md:pb-20">
      <div class="mx-auto max-w-6xl">
        {isMunicipalityConcept && municipalitySearchOptions.length > 0 && (
          <DirectorySearch
            options={municipalitySearchOptions}
            eyebrow={SHELL_COPY.directorySearchEyebrow}
            title={SHELL_COPY.directorySearchTitle}
            description={SHELL_COPY.directorySearchDescription}
            placeholder={SHELL_COPY.directorySearchPlaceholder}
            emptyText={SHELL_COPY.directorySearchEmpty}
            ariaLabel={SHELL_COPY.directorySearchAriaLabel}
            actionLabel={SHELL_COPY.directorySearchActionLabel}
            metaFallback={SHELL_COPY.directorySearchMetaFallback}
          />
        )}

        <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="eyebrow">{SHELL_COPY.listingEyebrow}</p>
            <h2 class="display-title mt-2 text-3xl font-bold text-slate-950 md:text-4xl">
              {SHELL_COPY.listingTitle}
            </h2>
          </div>
          <p class="max-w-xl text-sm leading-7 text-slate-600">{SHELL_COPY.listingDescription}</p>
        </div>

        {isMunicipalityConcept ? (
          <>
            <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
              {featuredMunicipalities.map((page) => (
                <MunicipalityCard page={page} />
              ))}
            </div>
            {featuredMunicipalities.length === 0 && (
              <p class="py-12 text-center text-slate-500">{SHELL_COPY.listingEmptyText}</p>
            )}
          </>
        ) : (
          <>
            <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
              {featuredPosts.map((post: CollectionEntry<'blog'>) => (
                <ArticleCard post={post} />
              ))}
            </div>

            {featuredPosts.length === 0 && (
              <p class="py-12 text-center text-slate-500">{SHELL_COPY.listingEmptyText}</p>
            )}
          </>
        )}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
