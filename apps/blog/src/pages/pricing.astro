---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { PRIMARY_CTA, SECONDARY_CTA, SHELL_COPY } from '../consts';

const title = 'Pricing';
const description = 'Start free and scale as your AI search visibility grows. Transparent pricing for teams of every size.';

const plans = [
  {
    name: 'Starter',
    price: '$0',
    period: 'forever',
    description: 'For individuals exploring GEO.',
    features: [
      '1 website',
      'llms.txt generator',
      'Basic structured data',
      'AI crawler audit',
      'Community support',
    ],
    cta: 'Get Started Free',
    href: '/signup/',
    highlighted: false,
  },
  {
    name: 'Growth',
    price: '$49',
    period: '/mo',
    description: 'For teams serious about AI visibility.',
    features: [
      '5 websites',
      'Advanced schema markup',
      'Content citability scoring',
      'Semantic HTML audits',
      'Weekly AI citation reports',
      'Priority support',
    ],
    cta: 'Start Free Trial',
    href: '/signup/',
    highlighted: true,
  },
  {
    name: 'Agency',
    price: '$199',
    period: '/mo',
    description: 'For agencies managing multiple brands.',
    features: [
      'Unlimited websites',
      'White-label reports',
      'API access',
      'Custom schema types',
      'Real-time citation monitoring',
      'Dedicated account manager',
    ],
    cta: 'Contact Sales',
    href: '/contact/',
    highlighted: false,
  },
];

const faqs = [
  { q: 'What is Generative Engine Optimization?', a: 'GEO is the practice of structuring your digital presence so AI language models like ChatGPT, Perplexity, Gemini, and Claude cite your brand as a relevant, authoritative source.' },
  { q: 'How long until I see results?', a: 'Most customers see their first AI citations within 2-4 weeks of deploying optimized content. Full share-of-voice improvements typically appear within 90 days.' },
  { q: 'Can I switch plans later?', a: 'Yes. Upgrade or downgrade at any time. Prorated billing means you only pay for what you use.' },
  { q: 'Do you offer custom Enterprise plans?', a: 'Yes. Contact us for dedicated infrastructure, SLAs, custom integrations, and volume pricing.' },
];

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
});

const pricingSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Visibility.help',
  description: 'AI-powered SEO and GEO optimization platform',
  url: 'https://visibility.help/pricing/',
  offers: plans.map((plan) => ({
    '@type': 'Offer',
    name: plan.name,
    description: plan.description,
    price: plan.price.replace('$', '').replace('/mo', '').replace('forever', '0'),
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: `https://visibility.help${plan.href}`,
  })),
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    ratingCount: '124',
  },
});

const breadcrumbItems = [
  { name: 'Pricing', url: 'https://visibility.help/pricing/' },
];
---

<BaseLayout title={title} description={description} canonicalUrl="https://visibility.help/pricing/" jsonLdScripts={[faqSchema, pricingSchema]} breadcrumbItems={breadcrumbItems}>
  <Header />
  <main>
    <!-- Hero -->
    <section class="px-4 pt-20 pb-14 md:pt-28 md:pb-20">
      <div class="section-container text-center">
        <p class="eyebrow reveal">Pricing</p>
        <h1 class="display-title mt-4 text-4xl font-bold leading-[1.05] sm:text-5xl md:text-6xl reveal reveal-delay-1">
          Simple, Transparent Pricing
        </h1>
        <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-[var(--ink-secondary)] reveal reveal-delay-2">
          Start free. Scale as your AI search visibility grows. No hidden fees, no contracts.
        </p>
      </div>
    </section>

    <!-- Plans -->
    <section class="px-4 pb-14 md:pb-24">
      <div class="section-container">
        <div class="grid gap-4 md:grid-cols-3 reveal">
          {plans.map((plan) => (
            <div class={`shell-card p-6 md:p-8 flex flex-col ${plan.highlighted ? 'ring-2 ring-[var(--accent)]' : ''}`}>
              {plan.highlighted && (
                <span class="inline-block self-start rounded-full bg-[var(--accent)] px-3 py-1 text-[11px] font-semibold text-white uppercase tracking-wider">Most Popular</span>
              )}
              <h2 class="mt-3 text-xl font-semibold">{plan.name}</h2>
              <p class="mt-2 text-sm text-[var(--ink-secondary)]">{plan.description}</p>
              <div class="mt-6 flex items-baseline gap-1">
                <span class="text-4xl font-bold tracking-tight">{plan.price}</span>
                <span class="text-sm text-[var(--ink-muted)]">{plan.period}</span>
              </div>
              <ul class="mt-8 flex-1 space-y-3">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-3 text-sm text-[var(--ink-secondary)]">
                    <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
              <a href={plan.href} class={`mt-8 block w-full rounded-full px-5 py-3 text-center text-sm font-semibold transition-all duration-300 ${plan.highlighted ? 'bg-[var(--accent)] text-white hover:bg-[var(--accent-hover)]' : 'bg-[var(--surface-tertiary)] text-[var(--ink)] hover:bg-[var(--border)]'}`}>
                {plan.cta}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="px-4 pb-24 md:pb-32">
      <div class="section-container">
        <div class="mx-auto max-w-2xl">
          <h2 class="text-center text-2xl font-bold md:text-3xl reveal">Frequently Asked Questions</h2>
          <div class="mt-10 space-y-3">
            {faqs.map((faq, i) => (
              <details class={`shell-card group p-5 reveal reveal-delay-${Math.min(i + 1, 3)}`} name="faq">
                <summary class="flex cursor-pointer list-none items-center justify-between text-sm font-semibold">
                  {faq.q}
                  <svg class="h-4 w-4 shrink-0 text-[var(--ink-muted)] transition-transform duration-300 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <p class="mt-3 text-sm leading-relaxed text-[var(--ink-secondary)]">{faq.a}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>