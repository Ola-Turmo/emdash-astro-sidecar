---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { PRIMARY_CTA, SECONDARY_CTA, SHELL_COPY } from '../consts';

const title = 'Pricing';
const description = 'Start generating content for free. Scale as your publishing volume grows. Transparent pricing with no surprises.';

const plans = [
  {
    name: 'Starter',
    price: '$0',
    period: 'forever',
    description: 'For solo founders testing the water.',
    features: [
      '1 website',
      '5 AI-generated articles / month',
      'Basic SEO optimization',
      'GEO-ready structure',
      'Community support',
    ],
    cta: 'Start Free',
    href: '/signup/',
    highlighted: false,
  },
  {
    name: 'Growth',
    price: '$49',
    period: '/mo',
    description: 'For teams publishing weekly.',
    features: [
      '3 websites',
      '50 AI-generated articles / month',
      'Advanced SEO + structured data',
      'Brand voice training',
      'Real-time SEO scoring',
      'Priority support',
    ],
    cta: 'Start Free Trial',
    href: '/signup/',
    highlighted: true,
  },
  {
    name: 'Scale',
    price: '$149',
    period: '/mo',
    description: 'For teams publishing daily across multiple brands.',
    features: [
      '10 websites',
      '200 AI-generated articles / month',
      'Bulk generation queue',
      'Custom schema types',
      'White-label exports',
      'API access',
      'Dedicated support',
    ],
    cta: 'Start Free Trial',
    href: '/signup/',
    highlighted: false,
  },
];

const faqs = [
  { q: 'What happens when I hit my article limit?', a: 'You can upgrade instantly from your dashboard. Your unused articles do not roll over to the next month.' },
  { q: 'How long does it take to generate an article?', a: 'Most articles are ready in 2-3 minutes. Long-form deep dives (3000+ words) may take up to 5 minutes.' },
  { q: 'Can I edit articles before publishing?', a: 'Yes. Every article goes to your review queue. You can edit, reject, or approve before it goes live.' },
  { q: 'Do I own the content?', a: 'Absolutely. Every word Emdash generates is yours. We do not train our models on your content or resell it.' },
  { q: 'Can I switch plans later?', a: 'Yes. Upgrade or downgrade at any time from your dashboard. Prorated billing means you only pay for what you use.' },
];

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
});

const pricingSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Emdash',
  description: 'AI content engine for websites',
  url: 'https://visibility.help/pricing/',
  offers: plans.map((plan) => ({
    '@type': 'Offer',
    name: plan.name,
    description: plan.description,
    price: plan.price.replace('$', '').replace('/mo', '').replace('forever', '0'),
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: `https://visibility.help${plan.href}`,
  })),
});

const breadcrumbItems = [
  { name: 'Pricing', url: 'https://visibility.help/pricing/' },
];
---

<BaseLayout title={title} description={description} canonicalUrl="https://visibility.help/pricing/" jsonLdScripts={[faqSchema, pricingSchema]} breadcrumbItems={breadcrumbItems}>
  <Header />
  <main>
    <!-- Hero -->
    <section class="px-4 pt-20 pb-14 md:pt-28 md:pb-20">
      <div class="section-container text-center">
        <p class="eyebrow reveal">Pricing</p>
        <h1 class="display-title mt-4 text-4xl font-bold leading-[1.05] sm:text-5xl md:text-6xl reveal reveal-delay-1">
          Publish More. Pay Less.
        </h1>
        <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-[var(--ink-secondary)] reveal reveal-delay-2">
          Start free and scale as your content engine warms up. Every plan includes full GEO optimization and structured data.
        </p>
      </div>
    </section>

    <!-- Plans -->
    <section class="px-4 pb-14 md:pb-24">
      <div class="section-container">
        <div class="grid gap-4 md:grid-cols-3 reveal">
          {plans.map((plan) => (
            <div class={`shell-card p-6 md:p-8 flex flex-col ${plan.highlighted ? 'ring-2 ring-[var(--accent)]' : ''}`}>
              {plan.highlighted && (
                <span class="inline-block self-start rounded-full bg-[var(--accent)] px-3 py-1 text-[11px] font-semibold text-white uppercase tracking-wider">Most Popular</span>
              )}
              <h2 class="mt-3 text-xl font-semibold">{plan.name}</h2>
              <p class="mt-2 text-sm text-[var(--ink-secondary)]">{plan.description}</p>
              <div class="mt-6 flex items-baseline gap-1">
                <span class="text-4xl font-bold tracking-tight">{plan.price}</span>
                <span class="text-sm text-[var(--ink-muted)]">{plan.period}</span>
              </div>
              <ul class="mt-8 flex-1 space-y-3">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-3 text-sm text-[var(--ink-secondary)]">
                    <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
              <a href={plan.href} class={`mt-8 block w-full rounded-full px-5 py-3 text-center text-sm font-semibold transition-all duration-300 ${plan.highlighted ? 'bg-[var(--accent)] text-white hover:bg-[var(--accent-hover)]' : 'bg-[var(--surface-tertiary)] text-[var(--ink)] hover:bg-[var(--border)]'}`}>
                {plan.cta}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="px-4 pb-24 md:pb-32">
      <div class="section-container">
        <div class="mx-auto max-w-2xl">
          <h2 class="text-center text-2xl font-bold md:text-3xl reveal">Frequently Asked Questions</h2>
          <div class="mt-10 space-y-3">
            {faqs.map((faq, i) => (
              <details class={`shell-card group p-5 reveal reveal-delay-${Math.min(i + 1, 3)}`} name="faq">
                <summary class="flex cursor-pointer list-none items-center justify-between text-sm font-semibold">
                  {faq.q}
                  <svg class="h-4 w-4 shrink-0 text-[var(--ink-muted)] transition-transform duration-300 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <p class="mt-3 text-sm leading-relaxed text-[var(--ink-secondary)]">{faq.a}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
