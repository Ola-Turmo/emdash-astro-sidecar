{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@lib/*": ["./src/lib/*"],
      "@content/*": ["./src/content/*"]
    }
  },
  "include": ["src/**/*", "*.config.*"],
  "exclude": ["dist", "node_modules"]
}
