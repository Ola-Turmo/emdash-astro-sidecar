      "requiredSecrets": []
    },
    {
      "name": "seo-files",
      "wranglerConfig": "apps/cloudflare/workers/seo-files/wrangler.toml",
      "kind": "route",
      "requiredSecrets": []
    },
    {
      "name": "scheduler",
      "wranglerConfig": "apps/cloudflare/workers/scheduler/wrangler.toml",
      "kind": "control-plane",
      "requiredSecrets": []
    },
    {
      "name": "orchestrator",
      "wranglerConfig": "apps/cloudflare/workers/orchestrator/wrangler.toml",
      "kind": "control-plane",
      "requiredSecrets": []
    },
    {
      "name": "browser-audit-worker",
      "wranglerConfig": "apps/cloudflare/workers/browser-audit-worker/wrangler.toml",
      "kind": "control-plane",
      "requiredSecrets": []
    },
    {
      "name": "research-worker",
      "wranglerConfig": "apps/cloudflare/workers/research-worker/wrangler.toml",
      "kind": "control-plane",
      "requiredSecrets": []
    },
    {
      "name": "draft-worker",
      "wranglerConfig": "apps/cloudflare/workers/draft-worker/wrangler.toml",
      "kind": "control-plane",
      "requiredSecrets": []
    },
    {
      "name": "eval-worker",
      "wranglerConfig": "apps/cloudflare/workers/eval-worker/wrangler.toml",
      "kind": "control-plane",
      "requiredSecrets": []
