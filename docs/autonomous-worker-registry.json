    {
      "name": "publish-worker",
      "wranglerConfig": "apps/cloudflare/workers/publish-worker/wrangler.toml",
      "kind": "control-plane",
      "requiredSecrets": []
    },
    {
      "name": "content-api",
      "wranglerConfig": "apps/cloudflare/workers/content-api/wrangler.toml",
      "kind": "control-plane",
      "requiredSecrets": ["CONTENT_API_TOKEN"]
    }
  ],
  "sharedSecrets": [
    "CLOUDFLARE_API_TOKEN",
    "CLOUDFLARE_ACCOUNT_ID"
  ],
  "optionalSecrets": [
    "THECLAWBAY_API_KEY",
    "MINIMAX_API_KEY",
    "CONTENT_API_URL",
    "ENABLE_AUTONOMOUS_PUBLICATION_SYNC"
