{
  "name": "emdash-astro-sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "dev": "pnpm --filter @emdash/blog dev",
    "clean": "pnpm -r run clean && rm -rf node_modules .astro dist",
    "test": "pnpm --filter @emdash/blog test"
  },
  "workspaces": ["apps/*", "packages/*"],
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
