{
  "name": "emdash-astro-sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "dev": "pnpm --filter @emdash/blog dev",
    "design:clone": "node ./scripts/design-clone.mjs",
    "generate:municipal-pages": "node ./scripts/generate-municipal-pages.mjs",
    "rollout:kommune-batches": "node ./scripts/rollout-kommune-batches.mjs",
    "promote:municipality-batch": "node ./scripts/promote-municipality-batch.mjs",
    "build:municipality-images": "python ./scripts/build-municipality-image-derivatives.py",
    "report:municipality": "node ./scripts/report-municipality-quality.mjs",
    "audit:municipality-batch": "node ./scripts/audit-municipality-batch.mjs",
    "purge:kommune-cache": "node ./scripts/purge-kommune-cache.mjs",
    "build:kommune": "node ./scripts/run-concept-command.mjs --site kurs-ing --concept kommune -- pnpm --filter @emdash/blog build",
    "sync:kommune-seo": "node ./scripts/run-concept-command.mjs --site kurs-ing --concept kommune -- pnpm sync:concept-seo",
    "deploy:kommune:pages": "node ./scripts/deploy-kommune-pages.mjs",
    "sync:guide-seo": "node ./scripts/sync-guide-seo-artifacts.mjs",
    "sync:concept-seo": "node ./scripts/sync-concept-seo-artifacts.mjs",
    "audit:deployed": "node ./scripts/audit-deployed-urls.mjs",
    "audit:deployed:lighthouse": "node ./scripts/audit-deployed-urls.mjs --lighthouse",
    "audit:deployed:psi": "node ./scripts/audit-deployed-urls.mjs --psi",
    "autonomous:check-env": "node ./scripts/check-autonomous-env.mjs",
    "autonomous:deploy-workers": "node ./scripts/deploy-autonomous-workers.mjs",
    "cloudflare:check-auth": "node ./scripts/check-cloudflare-auth.mjs --require-pages",
    "cloudflare:sync-secrets": "node ./scripts/sync-cloudflare-worker-secrets.mjs",
    "materialize:publications": "node ./scripts/materialize-publications.mjs",
    "providers:health": "node ./scripts/provider-healthcheck.mjs",
    "telemetry:crux": "node ./scripts/ingest-crux.mjs",
    "qa:copy": "node ./scripts/check-copy-quality.mjs",
    "qa:shell": "node ./scripts/check-shell-quality.mjs",
    "qa:municipality-release": "node ./scripts/check-municipality-release.mjs",
    "qa:municipality": "node ./scripts/check-municipality-content.mjs && node ./scripts/check-municipality-evidence.mjs && node ./scripts/check-municipality-rendered-truth.mjs && node ./scripts/check-municipality-release.mjs",
    "qa:encoding": "node ./scripts/check-text-encoding.mjs",
    "qa:mobile": "node ./scripts/check-mobile-layout.mjs",
    "report:lighthouse": "node ./scripts/check-lighthouse-budgets.mjs",
    "qa:lighthouse": "node ./scripts/check-lighthouse-budgets.mjs --strict",
    "report:accessibility": "node ./scripts/check-accessibility.mjs",
    "qa:accessibility": "node ./scripts/check-accessibility.mjs --strict",
    "report:field": "node ./scripts/check-field-performance.mjs",
    "report:traffic": "node ./scripts/report-edge-traffic.mjs",
    "report:security": "node ./scripts/check-security-headers.mjs",
    "report:pagespeed-public": "node ./scripts/report-pagespeed-public.mjs",
    "qa:field": "node ./scripts/check-field-performance.mjs --strict",
    "report:google-public": "node ./scripts/check-google-public-signals.mjs",
    "qa:google-public": "node ./scripts/check-google-public-signals.mjs --strict",
    "proof:rum": "node ./scripts/prove-browser-rum.mjs",
    "qa:rum": "node ./scripts/prove-browser-rum.mjs --strict",
    "report:structured-data": "node ./scripts/check-structured-data.mjs",
    "qa:structured-data": "node ./scripts/check-structured-data.mjs --strict",
    "report:crawlability": "node ./scripts/check-crawlability.mjs",
    "qa:crawlability": "node ./scripts/check-crawlability.mjs --strict",
    "report:parity": "node ./scripts/check-edge-parity.mjs",
    "qa:parity": "node ./scripts/check-edge-parity.mjs --strict",
    "report:release": "node ./scripts/report-release-health.mjs",
    "report:deps": "node ./scripts/report-dependency-audit.mjs",
  "qa:security": "node ./scripts/check-security-headers.mjs --strict",
  "qa:cloudflare": "node ./scripts/check-cloudflare-guardrails.mjs",
  "qa:root-routing": "node ./scripts/check-root-routing.mjs",
  "qa:ownership": "node ./scripts/check-route-ownership.mjs",
  "qa:config": "node ./scripts/check-host-config.mjs && node ./scripts/check-route-ownership.mjs",
  "qa:seo": "node ./scripts/check-seo-integrity.mjs && node ./scripts/check-indexability.mjs && node ./scripts/check-structured-data.mjs --strict && node ./scripts/check-crawlability.mjs --strict",
  "qa": "pnpm qa:copy && pnpm qa:shell && pnpm qa:municipality && pnpm qa:encoding && pnpm qa:mobile && pnpm qa:accessibility && pnpm qa:security && pnpm qa:cloudflare && pnpm qa:root-routing && pnpm qa:ownership && pnpm qa:config && pnpm qa:seo",
    "onboard:site": "node ./scripts/scaffold-site-onboarding.mjs",
    "export:ops": "node ./scripts/export-control-plane-backup.mjs",
    "verify:autonomous": "pnpm --filter @emdash/model-runtime build && pnpm --filter @emdash/model-runtime typecheck && pnpm --filter @emdash/autoresearch-core typecheck && pnpm --filter @emdash/content-evals typecheck && pnpm --filter @emdash/content-policy typecheck && pnpm --filter @emdash/cloudflare-guardrails typecheck && pnpm --filter @emdash/host-control typecheck && pnpm --filter @emdash/host-jobs typecheck && pnpm --filter @emdash/publish-engine typecheck && pnpm --filter @emdash/metrics-ingestion typecheck && pnpm --filter @emdash/ai typecheck",
    "verify:workers": "pnpm exec tsc -p apps/cloudflare/workers/tsconfig.typecheck.json --noEmit",
    "verify:blog": "pnpm --filter @emdash/blog check && pnpm --filter @emdash/blog build && pnpm sync:guide-seo",
    "verify:skills": "pnpm --filter @emdash-astro-sidecar/skills typecheck",
    "verify:concepts": "node ./scripts/verify-concepts.mjs",
    "verify": "pnpm verify:skills && pnpm verify:autonomous && pnpm verify:workers && pnpm verify:blog && pnpm verify:concepts && pnpm qa",
    "clean": "pnpm -r run clean && rm -rf node_modules .astro dist",
    "test": "pnpm --filter @emdash/blog test"
  },
  "workspaces": ["apps/*", "packages/*"],
  "devDependencies": {
    "@cloudflare/puppeteer": "^1.1.0",
    "playwright": "^1.59.1",
    "typescript": "^5.4.0"
  }
}
