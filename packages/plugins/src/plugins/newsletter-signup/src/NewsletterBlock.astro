---
interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  placeholder?: string;
  variant?: 'inline' | 'stacked';
}

const {
  title = 'Subscribe to our newsletter',
  description = 'Get the latest posts delivered straight to your inbox.',
  buttonText = 'Subscribe',
  placeholder = 'Enter your email',
  variant = 'stacked',
} = Astro.props;
---

<div class={`newsletter newsletter--${variant}`}>
  <div class="newsletter__content">
    <h3 class="newsletter__title">{title}</h3>
    <p class="newsletter__description">{description}</p>
  </div>
  
  <form class="newsletter__form" action="/api/subscribe" method="POST">
    <div class="newsletter__input-group">
      <input
        type="email"
        name="email"
        placeholder={placeholder}
        required
        class="newsletter__input"
      />
      <button type="submit" class="newsletter__button">
        {buttonText}
      </button>
    </div>
  </form>
</div>

<style>
  .newsletter {
    padding: 2rem;
    background: var(--color-neutral-50, #fafafa);
    border-radius: 1rem;
    border: 1px solid var(--color-neutral-200, #e4e4e7);
  }
  
  .newsletter--inline {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  
  .newsletter__title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  
  .newsletter__description {
    color: var(--color-neutral-600, #52525b);
    margin-bottom: 1rem;
  }
  
  .newsletter--inline .newsletter__description {
    margin-bottom: 0;
  }
  
  .newsletter__input-group {
    display: flex;
    gap: 0.5rem;
  }
  
  .newsletter--stacked .newsletter__input-group {
    flex-direction: column;
  }
  
  .newsletter__input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-neutral-300, #d4d4d8);
    border-radius: 0.5rem;
    font-size: 1rem;
  }
  
  .newsletter__input:focus {
    outline: none;
    border-color: var(--color-primary-500, #3b82f6);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }
  
  .newsletter__button {
    padding: 0.75rem 1.5rem;
    background: var(--color-primary-600, #2563eb);
    color: white;
    font-weight: 600;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: background 0.2s;
  }
  
  .newsletter__button:hover {
    background: var(--color-primary-700, #1d4ed8);
  }
</style>