{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@emdash/blog/*": ["./apps/blog/src/*"],
      "@emdash/theme-core/*": ["./packages/theme-core/src/*"],
      "@emdash/design-clone/*": ["./packages/design-clone/src/*"],
      "@emdash/ai/*": ["./packages/ai/src/*"],
      "@emdash/model-runtime/*": ["./packages/model-runtime/src/*"],
      "@emdash/autoresearch-core/*": ["./packages/autoresearch-core/src/*"],
      "@emdash/content-evals/*": ["./packages/content-evals/src/*"],
      "@emdash/content-policy/*": ["./packages/content-policy/src/*"],
      "@emdash/cloudflare-guardrails/*": ["./packages/cloudflare-guardrails/src/*"],
      "@emdash/host-control/*": ["./packages/host-control/src/*"],
      "@emdash/skills/*": ["./packages/skills/src/*"],
      "@emdash/plugins/*": ["./packages/plugins/src/*"]
    }
  }
}
